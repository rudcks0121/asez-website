---
/**
 * 모든 페이지가 공유하는 기본 레이아웃.
 * - <head> 메타 태그
 * - 글로벌 CSS 로드
 * - Tabler Icons (목업에서 사용)
 *
 * 사용 예:
 *   <BaseLayout title="About — ASEZ">
 *     <h1>About</h1>
 *   </BaseLayout>
 */
import "../styles/global.css";
import { getLangFromUrl } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "ko" | "kr";   // "kr"은 기존 호환용 alias
  image?: string;              // OG/Twitter 미리보기 이미지 (절대 URL 또는 /public 경로)
  type?: "website" | "article";
}

// URL이 우선, prop이 보조. lang attribute는 ISO 표준 "ko"로 정규화.
const urlLang = getLangFromUrl(Astro.url);
const propLang = Astro.props.lang === "kr" ? "ko" : Astro.props.lang;
const lang = propLang ?? urlLang;

const {
  title = lang === "ko"
    ? "ASEZ — 행복한 세상을 위해 A부터 Z까지"
    : "ASEZ — Save the Earth from A to Z",
  description = lang === "ko"
    ? "전 세계 175개국 7,500여 캠퍼스에서 활동하는 대학생 봉사단 ASEZ."
    : "A global network of student volunteers tackling climate change, plastic pollution, and community challenges across 175 countries.",
  image = "/images/pretoria-1000-trees.jpg",
  type = "website",
} = Astro.props;

// SEO: canonical URL과 OG URL은 절대 경로
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image.startsWith("http") ? image : new URL(image, Astro.site).href;

// hreflang: 같은 페이지의 영문/한국어 alternate URL
const path = Astro.url.pathname;
const altPath = lang === "ko"
  ? path.replace(/^\/ko/, "") || "/"
  : (path === "/" ? "/ko/" : `/ko${path}`);
const altUrl = Astro.site ? new URL(altPath, Astro.site).href : altPath;
const altLang = lang === "ko" ? "en" : "ko";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- Canonical + hreflang (i18n alternates) -->
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={altLang} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href={lang === "en" ? canonical : altUrl} />

    <!-- Open Graph (Facebook, KakaoTalk, LinkedIn, Slack 등) -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="ASEZ" />
    <meta property="og:locale" content={lang === "ko" ? "ko_KR" : "en_US"} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- robots: 정상 인덱싱, /admin은 별도 noindex -->
    <meta name="robots" content="index, follow" />
    <script is:inline>
      /* JS 사용 가능 표시 — scroll reveal 등 JS 기반 효과를 켜는 플래그.
         no-JS 환경에서는 이 클래스가 없어 reveal 요소가 처음부터 보임. */
      document.documentElement.classList.add("js");
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      /* IntersectionObserver — .reveal 클래스가 붙은 요소가 화면에 들어오면
         .in-view 클래스를 추가해 fade-up. 한 번만 트리거(unobserve)해서
         반복 애니메이션으로 어지럽지 않게. */
      const targets = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window && targets.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-view");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.08, rootMargin: "0px 0px -6% 0px" }
        );
        targets.forEach((el) => io.observe(el));
      } else {
        targets.forEach((el) => el.classList.add("in-view"));
      }

      /* === Number count-up ===
         사용: <span data-count-target="175">175</span>
         옵션: data-count-suffix="+" | "M+"  data-count-decimals="1"  data-count-format="comma" */
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      const counters = document.querySelectorAll<HTMLElement>("[data-count-target]");

      function format(n: number, el: HTMLElement) {
        const decimals = parseInt(el.dataset.countDecimals || "0", 10);
        const comma = el.dataset.countFormat === "comma";
        const suffix = el.dataset.countSuffix || "";
        let display: string;
        if (decimals > 0) display = n.toFixed(decimals);
        else if (comma) display = Math.round(n).toLocaleString();
        else display = Math.round(n).toString();
        return display + suffix;
      }

      function animate(el: HTMLElement) {
        const target = parseFloat(el.dataset.countTarget || "0");
        const duration = 1800;
        const start = performance.now();
        const ease = (t: number) => 1 - Math.pow(1 - t, 3);

        function tick(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const value = target * ease(progress);
          el.textContent = format(value, el);
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      if (counters.length && !reduceMotion && "IntersectionObserver" in window) {
        // 첫 페인트에서 0으로 시작하게 즉시 reset
        counters.forEach((el) => {
          el.textContent = format(0, el);
        });
        const co = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                animate(entry.target as HTMLElement);
                co.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.4 }
        );
        counters.forEach((el) => co.observe(el));
      }
      // reduceMotion 또는 no-IO: HTML의 최종 값 그대로 유지
    </script>
  </body>
</html>
