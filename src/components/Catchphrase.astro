---
import { getLangFromUrl } from "../i18n/utils";
import catchphrase from "../data/cms/catchphrase.json";

const lang = getLangFromUrl(Astro.url);
const c = (catchphrase as any)[lang] ?? catchphrase.en;
---

<section class="catchphrase reveal">
  <div class="inner">
    <p class="eyebrow">{c.eyebrow}</p>
    <p class="line" set:html={c.line}></p>
  </div>
</section>

<style>
  .catchphrase {
    padding: 72px var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .inner {
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }
  .eyebrow { margin-bottom: 22px; }
  .line {
    font-size: 30px;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.5px;
    margin: 0;
    color: var(--text-primary);
  }
  .line :global(strong) {
    color: var(--brand);
    font-weight: 500;
  }
  @media (max-width: 768px) {
    .catchphrase { padding: 56px 20px; }
    .line { font-size: 22px; letter-spacing: -0.3px; }
  }
</style>
