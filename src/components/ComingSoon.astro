---
/**
 * 콘텐츠가 아직 작성되지 않은 페이지에서 사용하는 placeholder 섹션.
 * "Coming soon" 메시지 + 홈으로 돌아가는 동선.
 */
interface Props {
  message?: string;
}
const {
  message = "This section is being built. Check back soon for stories, reports, and program details.",
} = Astro.props;
---

<section class="coming-soon reveal">
  <div class="inner">
    <i class="ti ti-progress-check icon"></i>
    <h2>Coming soon</h2>
    <p>{message}</p>
    <a href="/" class="back">
      <i class="ti ti-arrow-left"></i> Back to home
    </a>
  </div>
</section>

<style>
  .coming-soon {
    padding: 96px var(--section-pad-x);
    background: var(--bg-primary);
  }
  .inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }
  .icon {
    font-size: 44px;
    color: var(--brand);
    margin-bottom: 18px;
    display: inline-block;
  }
  h2 {
    font-size: var(--fs-h2);
    margin: 0 0 12px;
    letter-spacing: -0.4px;
  }
  p {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 28px;
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--brand);
    font-size: var(--fs-small);
    font-weight: 500;
    text-decoration: none;
    transition: gap 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .back:hover { gap: 10px; }
  .back i {
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .back:hover i { transform: translateX(-3px); }

  @media (max-width: 768px) {
    .coming-soon { padding: 64px 20px; }
  }
</style>
