---
import { getLangFromUrl, pathLocalized } from "../i18n/utils";
import projects from "../data/cms/projects.json";

const lang = getLangFromUrl(Astro.url);
const c = (projects as any)[lang] ?? projects.en;
const p = (path: string) => pathLocalized(path, lang);
---

<section
  class="main-projects reveal"
  data-cms-section="Major Projects"
  data-cms-href="/admin/#/collections/home/entries/projects"
>
  <div class="inner">
    <div class="head">
      <div class="head-text">
        <p class="eyebrow">{c.eyebrow}</p>
        <h2>{c.title}</h2>
        <p class="intro">{c.intro}</p>
      </div>
      <a href={p("/what-we-do")} class="view-all">
        {c.viewAll} <i class="ti ti-arrow-right"></i>
      </a>
    </div>

    <div class="grid">
      {projects.items.map((pr: any) => {
        const pc = pr[lang] ?? pr.en;
        return (
          <a class="project" href={p(pr.href)}>
            <div class="visual" style={`background: ${pr.bg};`}>
              <i class={`ti ${pr.icon}`} style={`color: ${pr.iconColor};`}></i>
            </div>
            <div class="body">
              <h3>{pc.title}</h3>
              <p class="tagline">{pc.tagline}</p>
              <p class="desc">{pc.desc}</p>
              <span class="more">
                {c.learnMore} <i class="ti ti-arrow-right"></i>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .main-projects {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 48px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .head-text { max-width: 640px; }
  .head h2 { font-size: var(--fs-h2); margin: 0 0 14px; letter-spacing: -0.4px; }
  .head .intro { font-size: var(--fs-body); color: var(--text-secondary); line-height: 1.6; margin: 0; }
  .view-all {
    font-size: var(--fs-small);
    color: var(--brand);
    text-decoration: none;
    font-weight: 500;
    flex-shrink: 0;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .project {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 0.5px solid var(--border);
    background: var(--bg-primary);
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
  }
  .project:hover {
    border-color: var(--border-strong);
    transform: translateY(-4px);
    box-shadow: 0 10px 32px rgba(4, 44, 83, 0.1);
  }
  .visual {
    aspect-ratio: 16/6;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .visual i { font-size: 52px; transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1); }
  .project:hover .visual i { transform: scale(1.15); }
  .body { padding: 28px 30px 30px; flex: 1; display: flex; flex-direction: column; }
  .body h3 { font-size: 22px; margin: 0 0 4px; line-height: var(--lh-snug); letter-spacing: -0.3px; }
  .tagline { font-size: 17px; color: var(--brand); font-weight: 500; margin: 0 0 14px; }
  .desc { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.6; margin: 0 0 18px; flex: 1; }
  .more {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--brand);
  }
  .more i { transition: transform 0.2s; }
  .project:hover .more i { transform: translateX(4px); }

  @media (max-width: 768px) {
    .main-projects { padding: 56px 20px; }
    .grid { grid-template-columns: 1fr; }
    .body { padding: 22px 24px 24px; }
    .body h3 { font-size: 20px; }
    .tagline { font-size: 16px; }
  }
</style>
