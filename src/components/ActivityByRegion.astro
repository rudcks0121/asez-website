---
/**
 * 5개 region별 대표 활동 — 한눈에 보기.
 * /where-we-work 페이지로 가지 않아도 홈에서 글로벌 임팩트 파악 가능.
 */
const regions = [
  {
    name: "Asia",
    countries: 48,
    img: "https://asez.org/wp-content/uploads/2024/10/thum_zero_plastic_2040.jpg",
    activities: ["Plastic-Free India", "Blue Carbon Korea", "Forest forums Japan"],
    href: "/where-we-work#asia",
  },
  {
    name: "Americas",
    countries: 35,
    img: "https://asez.org/wp-content/uploads/2024/07/thum_us_president_awards.png",
    activities: ["U.S. Presidential Service", "Amazon protection Brazil", "Coastal cleanups"],
    href: "/where-we-work#americas",
  },
  {
    name: "Europe",
    countries: 44,
    img: "https://asez.org/wp-content/uploads/2024/07/thum_green_awards.png",
    activities: ["Green Apple Awards", "Climate policy forums", "Plastic reduction UK"],
    href: "/where-we-work#europe",
  },
  {
    name: "Africa",
    countries: 38,
    img: "https://asez.org/wp-content/uploads/2026/04/20260322_%EB%82%A8%EC%95%84%ED%94%84%EB%A6%AC%EC%B9%B4%EA%B3%B5%ED%99%94%EA%B5%AD_C_%EB%82%A8%EC%95%84%ED%94%84%EB%A6%AC%EC%B9%B4%EA%B3%B5%ED%99%94%EA%B5%AD-%ED%94%84%EB%A6%AC%ED%86%A0%EB%A6%AC%EC%95%84_ASEZ-%EB%82%98%EB%AC%B4%EC%8B%AC%EA%B8%B0-100%EA%B7%B8%EB%A3%A8_%EC%B4%88%EC%BD%94%EC%97%90-%EC%B4%88%EB%93%B1%ED%95%99%EA%B5%90-%ED%8F%AC%ED%95%A8-9%EA%B0%9C-%EC%9E%A5%EC%86%8C_0000181_ASEZIUBA.jpg",
    activities: ["Pretoria tree planting", "UNCCD partnership", "Kenya conservation"],
    href: "/where-we-work#africa",
  },
  {
    name: "Oceania",
    countries: 10,
    img: "https://asez.org/wp-content/uploads/2026/03/beautiful-canopy-of-green-trees-looking-upwards-2026-01-11-10-01-30-utc-1.jpg",
    activities: ["Blue Carbon Pacific", "Reef protection AU", "NZ chapter network"],
    href: "/where-we-work#oceania",
  },
];
---

<section class="by-region reveal">
  <div class="inner">
    <div class="head">
      <div class="head-text">
        <p class="eyebrow">Activity by region</p>
        <h2>Local action, global movement.</h2>
        <p class="intro">
          ASEZ chapters are organized regionally. Here's what's happening
          on each continent right now.
        </p>
      </div>
      <a href="/where-we-work" class="view-all">
        Full map <i class="ti ti-arrow-right"></i>
      </a>
    </div>

    <div class="grid">
      {regions.map((r) => (
        <a class="region" href={r.href}>
          <div class="media">
            <img src={r.img} alt={r.name} loading="lazy" />
            <div class="badge">
              <span class="cnt">{r.countries}</span>
              <span class="cnt-lbl">countries</span>
            </div>
          </div>
          <div class="body">
            <h3>{r.name}</h3>
            <ul class="acts">
              {r.activities.map((a) => (
                <li>
                  <i class="ti ti-point"></i> {a}
                </li>
              ))}
            </ul>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .by-region {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 40px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .head-text { max-width: 640px; }
  .head h2 {
    font-size: var(--fs-h2);
    margin: 0 0 14px;
    letter-spacing: -0.4px;
  }
  .head .intro {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  .view-all {
    font-size: var(--fs-small);
    color: var(--brand);
    text-decoration: none;
    font-weight: 500;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
  }
  .region {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 0.5px solid var(--border);
    background: var(--bg-primary);
    color: var(--text-primary);
    text-decoration: none;
    transition:
      border-color 0.2s,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease;
  }
  .region:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(4, 44, 83, 0.08);
  }
  .media {
    aspect-ratio: 4/3;
    overflow: hidden;
    position: relative;
  }
  .media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .region:hover .media img { transform: scale(1.06); }

  .badge {
    position: absolute;
    left: 12px;
    top: 12px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: var(--radius-md);
    padding: 6px 10px;
    display: flex;
    align-items: baseline;
    gap: 5px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }
  .cnt {
    font-size: 20px;
    font-weight: 800;
    color: var(--brand);
    line-height: 1;
    letter-spacing: -0.8px;
  }
  .cnt-lbl {
    font-size: 10px;
    color: var(--text-secondary);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .body {
    padding: 18px 18px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .body h3 {
    font-size: 17px;
    margin: 0 0 12px;
    letter-spacing: -0.2px;
  }
  .acts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .acts li {
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.4;
    display: flex;
    align-items: flex-start;
    gap: 4px;
  }
  .acts i {
    color: var(--brand);
    font-size: 14px;
    line-height: 1.2;
    flex-shrink: 0;
  }

  @media (max-width: 1100px) {
    .grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 700px) {
    .by-region { padding: 56px 20px; }
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 440px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
