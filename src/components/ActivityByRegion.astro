---
import { useTranslations, getLangFromUrl, pathLocalized } from "../i18n/utils";
const t = useTranslations(Astro.url);
const lang = getLangFromUrl(Astro.url);
const p = (path: string) => pathLocalized(path, lang);

// 활동 목록은 짧고 사이트 전반에서 일관됨. 한국어/영문 모두 직관적이라 인라인 매핑.
const isKo = lang === "ko";

// 대륙 실루엣 SVG path (간소화). viewBox 100x100.
const continentPath: Record<string, string> = {
  asia:
    "M8,38 L18,22 L32,16 L48,14 L62,18 L74,16 L84,22 L92,32 L90,42 L84,46 L78,50 L72,48 L66,54 L60,52 L56,62 L62,68 L58,76 L52,82 L46,80 L42,72 L36,76 L30,72 L24,64 L18,58 L12,50 Z M70,58 L76,62 L74,68 L68,66 Z",
  americas:
    "M28,12 L42,8 L52,14 L48,22 L52,30 L48,38 L44,42 L40,48 L46,52 L48,60 L46,68 L48,76 L44,84 L40,90 L34,88 L32,80 L30,72 L28,64 L24,56 L22,48 L20,40 L24,32 L22,24 L24,18 Z",
  europe:
    "M14,42 L22,32 L34,28 L46,26 L58,30 L66,26 L74,30 L82,34 L86,42 L82,48 L74,52 L66,50 L58,56 L50,58 L42,60 L34,58 L26,56 L18,52 L14,48 Z M76,22 L82,24 L80,30 L74,28 Z",
  africa:
    "M30,16 L46,12 L60,14 L72,20 L78,30 L80,42 L78,52 L72,62 L66,72 L60,80 L52,86 L46,84 L40,76 L36,68 L32,58 L28,48 L26,38 L24,28 L26,20 Z",
  oceania:
    "M30,46 L46,40 L62,42 L74,48 L78,56 L72,64 L60,68 L46,66 L34,60 L28,54 Z",
};

const regions = [
  {
    name: t("region.asia"),
    slug: "asia",
    countries: 48,
    img: "/images/zero-plastic-2040.jpg",
    activities: isKo
      ? ["Plastic-Free India", "Blue Carbon 한국", "산림 포럼 일본"]
      : ["Plastic-Free India", "Blue Carbon Korea", "Forest forums Japan"],
    href: p("/where-we-work") + "#asia",
  },
  {
    name: t("region.americas"),
    slug: "americas",
    countries: 35,
    img: "/images/award-us-president.png",
    activities: isKo
      ? ["미국 대통령 봉사상", "아마존 보호 브라질", "해안 정화 활동"]
      : ["U.S. Presidential Service", "Amazon protection Brazil", "Coastal cleanups"],
    href: p("/where-we-work") + "#americas",
  },
  {
    name: t("region.europe"),
    slug: "europe",
    countries: 44,
    img: "/images/award-green.png",
    activities: isKo
      ? ["Green Apple Awards", "기후 정책 포럼", "플라스틱 감축 영국"]
      : ["Green Apple Awards", "Climate policy forums", "Plastic reduction UK"],
    href: p("/where-we-work") + "#europe",
  },
  {
    name: t("region.africa"),
    slug: "africa",
    countries: 38,
    img: "/images/pretoria-1000-trees.jpg",
    activities: isKo
      ? ["프리토리아 나무 심기", "UNCCD 파트너십", "케냐 보존 활동"]
      : ["Pretoria tree planting", "UNCCD partnership", "Kenya conservation"],
    href: p("/where-we-work") + "#africa",
  },
  {
    name: t("region.oceania"),
    slug: "oceania",
    countries: 10,
    img: "/images/forest-canopy.jpg",
    activities: isKo
      ? ["Blue Carbon 태평양", "산호초 보호 호주", "NZ 챕터 네트워크"]
      : ["Blue Carbon Pacific", "Reef protection AU", "NZ chapter network"],
    href: p("/where-we-work") + "#oceania",
  },
];
---

<section class="by-region reveal">
  <div class="inner">
    <div class="head">
      <div class="head-text">
        <p class="eyebrow">{t("region.eyebrow")}</p>
        <h2>{t("region.title")}</h2>
        <p class="intro">{t("region.intro")}</p>
      </div>
      <a href={p("/where-we-work")} class="view-all">
        {t("region.full-map")} <i class="ti ti-arrow-right"></i>
      </a>
    </div>

    <div class="grid">
      {regions.map((r) => (
        <a class="region" href={r.href}>
          <div class="media">
            <img src={r.img} alt={r.name} loading="lazy" />
            <div class="cnt-badge">
              <span class="cnt">{r.countries}</span>
              <span class="cnt-lbl">{t("region.countries")}</span>
            </div>
          </div>
          <div class="body">
            <svg
              class="continent-shape"
              viewBox="0 0 100 100"
              aria-hidden="true"
              focusable="false"
            >
              <path d={continentPath[r.slug]} />
            </svg>
            <h3>{r.name}</h3>
            <ul class="acts">
              {r.activities.map((a) => (
                <li>
                  <i class="ti ti-point-filled"></i> {a}
                </li>
              ))}
            </ul>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .by-region {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 40px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .head-text { max-width: 640px; }
  .head h2 { font-size: var(--fs-h2); margin: 0 0 14px; letter-spacing: -0.4px; }
  .head .intro { font-size: var(--fs-body); color: var(--text-secondary); line-height: 1.6; margin: 0; }
  .view-all { font-size: var(--fs-small); color: var(--brand); text-decoration: none; font-weight: 500; }
  .grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
  }
  .region {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 0.5px solid var(--border);
    background: var(--bg-primary);
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
  }
  .region:hover {
    border-color: var(--border-strong);
    transform: translateY(-4px);
    box-shadow: 0 10px 28px rgba(4, 44, 83, 0.12);
  }
  .media { aspect-ratio: 4/3; overflow: hidden; position: relative; }
  .media img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .region:hover .media img { transform: scale(1.08); }

  .cnt-badge {
    position: absolute; left: 12px; top: 12px;
    background: rgba(255, 255, 255, 0.96);
    border-radius: var(--radius-md);
    padding: 6px 10px;
    display: flex; align-items: baseline; gap: 5px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  .cnt { font-size: 20px; font-weight: 800; color: var(--brand); line-height: 1; letter-spacing: -0.8px; }
  .cnt-lbl { font-size: 10px; color: var(--text-secondary); letter-spacing: 0.5px; text-transform: uppercase; }

  .body {
    padding: 18px 18px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .continent-shape {
    position: absolute;
    right: -14px;
    bottom: -10px;
    width: 96px;
    height: 96px;
    fill: var(--brand-100);
    opacity: 0.55;
    pointer-events: none;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s;
  }
  .region:hover .continent-shape {
    transform: translate(-2px, -2px) rotate(-3deg);
    opacity: 0.75;
  }
  .body h3 { font-size: 17px; margin: 0 0 12px; letter-spacing: -0.2px; display: flex; align-items: center; gap: 6px; position: relative; z-index: 1; }
  .acts { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; position: relative; z-index: 1; }
  .acts li {
    font-size: 12px; color: var(--text-secondary); line-height: 1.4;
    display: flex; align-items: flex-start; gap: 4px;
  }
  .acts i { color: var(--brand); font-size: 10px; margin-top: 4px; flex-shrink: 0; }

  @media (max-width: 1024px) {
    .grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 768px) {
    .by-region { padding: 56px 20px; }
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
