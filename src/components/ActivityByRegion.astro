---
import { getLangFromUrl, pathLocalized } from "../i18n/utils";
import { countriesByContinent, continentViewBox } from "../lib/world-map";
import regionsData from "../data/cms/regions.json";

const lang = getLangFromUrl(Astro.url);
const p = (path: string) => pathLocalized(path, lang);
const c = (regionsData as any)[lang] ?? regionsData.en;

const regions = regionsData.items.map((r: any) => {
  const rc = r[lang] ?? r.en;
  return {
    slug: r.slug,
    countries: r.countries,
    img: r.image,
    name: rc.name,
    activities: rc.activities,
    href: p(r.href.split("#")[0]) + (r.href.includes("#") ? "#" + r.href.split("#")[1] : ""),
  };
});
---

<section class="by-region reveal">
  <div class="inner">
    <div class="head">
      <div class="head-text">
        <p class="eyebrow">{c.eyebrow}</p>
        <h2>{c.title}</h2>
        <p class="intro">{c.intro}</p>
      </div>
      <a href={p("/where-we-work")} class="view-all">
        {c.viewAll} <i class="ti ti-arrow-right"></i>
      </a>
    </div>

    <div class="grid">
      {regions.map((r) => (
        <a class="region" href={r.href}>
          <div class="media">
            <img src={r.img} alt={r.name} loading="lazy" />
            <div class="cnt-badge">
              <span class="cnt">{r.countries}</span>
              <span class="cnt-lbl">{c.countries}</span>
            </div>
          </div>
          <div class="body">
            <div class="body-head">
              <h3>{r.name}</h3>
              <div class="cont-stamp" aria-hidden="true">
                <svg
                  class="cont-icon"
                  viewBox={continentViewBox[r.slug]}
                  preserveAspectRatio="xMidYMid meet"
                  focusable="false"
                >
                  {(countriesByContinent[r.slug] ?? []).map((c) => (
                    <path d={c.d} />
                  ))}
                </svg>
              </div>
            </div>
            <ul class="acts">
              {r.activities.map((a) => (
                <li>
                  <i class="ti ti-point-filled"></i> {a}
                </li>
              ))}
            </ul>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .by-region {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 40px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .head-text { max-width: 640px; }
  .head h2 { font-size: var(--fs-h2); margin: 0 0 14px; letter-spacing: -0.4px; }
  .head .intro { font-size: var(--fs-body); color: var(--text-secondary); line-height: 1.6; margin: 0; }
  .view-all { font-size: var(--fs-small); color: var(--brand); text-decoration: none; font-weight: 500; }
  .grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
  }
  .region {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 0.5px solid var(--border);
    background: var(--bg-primary);
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
  }
  .region:hover {
    border-color: var(--border-strong);
    transform: translateY(-4px);
    box-shadow: 0 10px 28px rgba(4, 44, 83, 0.12);
  }
  .media { aspect-ratio: 4/3; overflow: hidden; position: relative; }
  .media img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .region:hover .media img { transform: scale(1.08); }

  .cnt-badge {
    position: absolute; left: 12px; top: 12px;
    background: rgba(255, 255, 255, 0.96);
    border-radius: var(--radius-md);
    padding: 6px 10px;
    display: flex; align-items: baseline; gap: 5px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  .cnt { font-size: 20px; font-weight: 800; color: var(--brand); line-height: 1; letter-spacing: -0.8px; }
  .cnt-lbl { font-size: 10px; color: var(--text-secondary); letter-spacing: 0.5px; text-transform: uppercase; }

  .body {
    padding: 18px 18px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .body-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }
  .body h3 {
    font-size: 17px;
    margin: 0;
    letter-spacing: -0.2px;
    flex: 1;
    min-width: 0;
  }
  .acts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .cont-stamp {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    padding: 7px;
    flex-shrink: 0;
    background:
      radial-gradient(circle at 30% 25%, rgba(255,255,255,0.9), rgba(255,255,255,0) 70%),
      linear-gradient(135deg, var(--brand-50) 0%, var(--brand-100) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      0 2px 8px rgba(32, 96, 173, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.3s ease,
      box-shadow 0.3s ease;
  }
  .cont-icon {
    width: 100%;
    height: 100%;
    display: block;
    overflow: hidden;
  }
  .cont-icon :global(path) {
    fill: var(--brand);
    stroke: white;
    stroke-width: 0.5;
    stroke-linejoin: round;
    transition: fill 0.25s ease;
  }
  .region:hover .cont-stamp {
    transform: rotate(-5deg) scale(1.08);
    background:
      radial-gradient(circle at 30% 25%, rgba(255,255,255,0.5), rgba(255,255,255,0) 70%),
      linear-gradient(135deg, var(--brand) 0%, var(--brand-dark, #1a4d8c) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      0 8px 20px rgba(32, 96, 173, 0.25);
  }
  .region:hover .cont-icon :global(path) {
    fill: white;
    stroke: rgba(255, 255, 255, 0.4);
  }
  .acts li {
    font-size: 12px; color: var(--text-secondary); line-height: 1.4;
    display: flex; align-items: flex-start; gap: 4px;
  }
  .acts i { color: var(--brand); font-size: 10px; margin-top: 4px; flex-shrink: 0; }

  @media (max-width: 1024px) {
    .grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 768px) {
    .by-region { padding: 56px 20px; }
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
