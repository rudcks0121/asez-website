---
interface Props {
  category: string;
  title: string;
  date: string;
  imgUrl?: string;
  bg?: string;
  iconColor?: string;
  pillBg: string;
  pillColor: string;
  href?: string;
}
const {
  category,
  title,
  date,
  imgUrl,
  bg = "var(--brand-100)",
  iconColor = "var(--brand-900)",
  pillBg,
  pillColor,
  href = "#",
} = Astro.props;
---

<a class="card" href={href}>
  <div class="media" style={!imgUrl ? `background: ${bg};` : undefined}>
    {imgUrl ? (
      <img src={imgUrl} alt={title} loading="lazy" />
    ) : (
      <i class="ti ti-photo" style={`color: ${iconColor};`}></i>
    )}
  </div>
  <div class="body">
    <span class="pill" style={`background: ${pillBg}; color: ${pillColor};`}>
      {category}
    </span>
    <h3>{title}</h3>
    <p class="date">{date}</p>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 0.5px solid var(--border);
    background: var(--bg-primary);
    color: var(--text-primary);
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    height: 100%;
  }
  .card:hover {
    border-color: var(--border-strong);
    transform: translateY(-4px);
    box-shadow: 0 10px 28px rgba(4, 44, 83, 0.1);
  }
  .media {
    aspect-ratio: 16/10;
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
    /* display:flex 제거 — img를 absolute로 띄워서 intrinsic size가
       container를 늘리는 것을 막음 (큰 세로 사진도 안전하게 cover). */
  }
  .media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .card:hover .media img {
    transform: scale(1.06);
  }
  .media > i {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 38px;
  }

  .body {
    padding: 20px 22px 22px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .pill {
    font-size: var(--fs-caption);
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    display: inline-block;
    align-self: flex-start;
    font-weight: 500;
  }
  h3 {
    font-size: 17px;
    margin: 14px 0 12px;
    line-height: var(--lh-snug);
  }
  .date {
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
    margin: auto 0 0;
  }
</style>
