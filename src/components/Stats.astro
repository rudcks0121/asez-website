---
import { getLangFromUrl } from "../i18n/utils";
import stats from "../data/cms/stats.json";

const lang = getLangFromUrl(Astro.url);
const c = (stats as any)[lang] ?? stats.en;
---

<section class="stats reveal">
  <div class="inner">
    <div class="head">
      <p class="eyebrow">{c.eyebrow}</p>
      <h2>{c.title}</h2>
    </div>
    <div class="grid">
      {stats.items.map((s: any) => {
        const sc = s[lang] ?? s.en;
        return (
          <div class="stat">
            <i class={`ti ${s.icon} icon`}></i>
            <div
              class="num"
              data-count-target={s.target}
              data-count-suffix={s.suffix}
              data-count-decimals={s.decimals}
              data-count-format={s.format}
            >
              {s.num}
            </div>
            <div class="label">{sc.label}</div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .stats {
    background: var(--bg-primary);
    padding: var(--section-pad-y) var(--section-pad-x);
    border-top: 0.5px solid var(--border);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .head { margin-bottom: 40px; max-width: 600px; }
  .head h2 { font-size: var(--fs-h2); margin: 0; }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 28px;
  }
  .stat {
    border-top: 0.5px solid var(--border-strong);
    padding-top: 22px;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .stat:hover { transform: translateY(-3px); }
  .icon {
    font-size: 22px;
    color: var(--brand);
    margin-bottom: 14px;
    display: inline-block;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .stat:hover .icon { transform: scale(1.2) rotate(-8deg); }
  .num {
    font-size: var(--fs-stat);
    font-weight: 800;
    color: var(--brand);
    line-height: 1;
    letter-spacing: -2.5px;
  }
  .label {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    margin-top: 12px;
  }
  @media (max-width: 768px) {
    .stats { padding: 48px 20px; }
    .head h2 { font-size: 22px; }
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 24px; }
    .num { font-size: 42px; }
  }
</style>
