---
const stats = [
  { num: "175", label: "Countries" },
  { num: "7,500", label: "Campuses" },
  { num: "2.1M+", label: "Volunteer hours" },
  { num: "17", label: "UN SDGs supported" },
];
---

<section class="stats reveal">
  <div class="inner">
    <div class="head">
      <p class="eyebrow">Our global footprint</p>
      <h2>A movement, in numbers.</h2>
    </div>
    <div class="grid">
      {stats.map((s) => (
        <div class="stat">
          <div class="num">{s.num}</div>
          <div class="label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    background: var(--bg-primary);
    padding: var(--section-pad-y) var(--section-pad-x);
    border-top: 0.5px solid var(--border);
  }
  .inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .head { margin-bottom: 40px; max-width: 600px; }
  .head h2 {
    font-size: var(--fs-h2);
    margin: 0;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 28px;
  }
  .stat {
    border-top: 0.5px solid var(--border-strong);
    padding-top: 22px;
  }
  .num {
    font-size: var(--fs-stat);
    font-weight: 800;
    color: var(--brand);
    line-height: 1;
    letter-spacing: -2.5px;
  }
  .label {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    margin-top: 12px;
  }

  @media (max-width: 768px) {
    .stats { padding: 48px 20px; }
    .head h2 { font-size: 22px; }
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 24px; }
    .num { font-size: 42px; }
  }
</style>
