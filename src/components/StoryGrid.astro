---
import { getCollection } from "astro:content";
import StoryCard from "./StoryCard.astro";

/**
 * 홈페이지의 Latest stories — 컬렉션에서 최신 3개만.
 */
const all = await getCollection("stories", ({ data }) => !data.draft);
const stories = all
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<section class="section reveal">
  <div class="inner">
    <div class="head">
      <div>
        <p class="eyebrow">Field stories</p>
        <h2>Latest from the field.</h2>
      </div>
      <a href="/stories" class="view-all">
        All stories <i class="ti ti-arrow-right"></i>
      </a>
    </div>
    <div class="grid">
      {stories.map((s) => (
        <StoryCard
          category={s.data.category}
          title={s.data.title}
          date={fmt(s.data.date)}
          imgUrl={s.data.image}
          pillBg={s.data.pillBg}
          pillColor={s.data.pillColor}
          href={`/stories/${s.id}`}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .head h2 {
    font-size: var(--fs-h2);
    margin: 0;
  }
  .view-all {
    font-size: var(--fs-small);
    color: var(--brand);
    text-decoration: none;
    font-weight: 500;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 768px) {
    .section { padding: 56px 20px; }
    .head h2 { font-size: 24px; }
  }
  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
