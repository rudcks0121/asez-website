---
import { getCollection } from "astro:content";
import { useTranslations, getLangFromUrl, pathLocalized } from "../i18n/utils";
import StoryCard from "./StoryCard.astro";

const t = useTranslations(Astro.url);
const lang = getLangFromUrl(Astro.url);

const all = await getCollection("stories", ({ data }) => !data.draft);
const stories = all
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString(lang === "ko" ? "ko-KR" : "en-US", {
    year: "numeric",
    month: lang === "ko" ? "long" : "long",
    day: "numeric",
  });
---

<section class="section reveal">
  <div class="inner">
    <div class="head">
      <div>
        <p class="eyebrow">{t("stories.eyebrow")}</p>
        <h2>{t("stories.title")}</h2>
      </div>
      <a href={pathLocalized("/stories", lang)} class="view-all">
        {t("stories.view-all")} <i class="ti ti-arrow-right"></i>
      </a>
    </div>
    <div class="grid">
      {stories.map((s) => (
        <StoryCard
          category={s.data.category}
          title={s.data.title}
          date={fmt(s.data.date)}
          imgUrl={s.data.image}
          pillBg={s.data.pillBg}
          pillColor={s.data.pillColor}
          href={pathLocalized(`/stories/${s.id}`, lang)}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .head {
    display: flex; align-items: end; justify-content: space-between;
    margin-bottom: 40px; flex-wrap: wrap; gap: 16px;
  }
  .head h2 { font-size: var(--fs-h2); margin: 0; }
  .view-all { font-size: var(--fs-small); color: var(--brand); text-decoration: none; font-weight: 500; }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 768px) {
    .section { padding: 56px 20px; }
    .head h2 { font-size: 24px; }
  }
  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
