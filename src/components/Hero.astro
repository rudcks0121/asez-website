---
import { useTranslations, getLangFromUrl, pathLocalized } from "../i18n/utils";

const t = useTranslations(Astro.url);
const lang = getLangFromUrl(Astro.url);

const heroImage =
  "https://asez.org/wp-content/uploads/2026/04/20260322_%EB%82%A8%EC%95%84%ED%94%84%EB%A6%AC%EC%B9%B4%EA%B3%B5%ED%99%94%EA%B5%AD_C_%EB%82%A8%EC%95%84%ED%94%84%EB%A6%AC%EC%B9%B4%EA%B3%B5%ED%99%94%EA%B5%AD-%ED%94%84%EB%A6%AC%ED%86%A0%EB%A6%AC%EC%95%84_ASEZ-%EB%82%98%EB%AC%B4%EC%8B%AC%EA%B8%B0-100%EA%B7%B8%EB%A3%A8_%EC%B4%88%EC%BD%94%EC%97%90-%EC%B4%88%EB%93%B1%ED%95%99%EA%B5%90-%ED%8F%AC%ED%95%A8-9%EA%B0%9C-%EC%9E%A5%EC%86%8C_0000181_ASEZIUBA.jpg";
---

<section class="hero" style={`background-image: url('${heroImage}');`}>
  <div class="overlay"></div>
  <div class="inner">
    <p class="eyebrow light">{t("hero.eyebrow")}</p>
    <h1>{t("hero.title.line1")}<br />{t("hero.title.line2")}</h1>
    <p class="lead">{t("hero.lead")}</p>
    <div class="cta">
      <a href={pathLocalized("/get-involved", lang)} class="btn-primary">{t("hero.cta.primary")}</a>
      <a href={pathLocalized("/what-we-do", lang)} class="btn-ghost">
        {t("hero.cta.secondary")} <i class="ti ti-arrow-right"></i>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 520px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: white;
    display: flex;
    align-items: center;
  }
  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(4, 44, 83, 0.88) 0%,
      rgba(4, 44, 83, 0.72) 55%,
      rgba(4, 44, 83, 0.55) 100%
    );
  }
  .inner {
    position: relative;
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 72px var(--section-pad-x);
  }
  .eyebrow.light { color: rgba(255, 255, 255, 0.92); }
  h1 {
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    letter-spacing: -1.2px;
    margin: 0 0 22px;
    max-width: 820px;
  }
  .lead {
    font-size: 18px;
    line-height: 1.55;
    max-width: 600px;
    margin: 0 0 32px;
    opacity: 0.92;
  }
  .cta { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
  .btn-primary,
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 13px 24px;
    border-radius: var(--radius-md);
    font-size: var(--fs-small);
    font-weight: 500;
    text-decoration: none;
    transition:
      background 0.2s ease,
      transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }
  .btn-primary {
    background: white;
    color: var(--brand);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .btn-primary:hover {
    background: var(--brand-50);
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);
  }
  .btn-ghost {
    background: transparent;
    color: white;
    border: 0.5px solid rgba(255, 255, 255, 0.6);
  }
  .btn-ghost i {
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.9);
  }
  .btn-ghost:hover i { transform: translateX(3px); }

  @media (max-width: 768px) {
    .hero { min-height: 420px; }
    .inner { padding: 56px 20px; }
    h1 { font-size: 32px; letter-spacing: -0.8px; }
    .lead { font-size: 16px; }
  }
</style>
