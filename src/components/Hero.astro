---
import { getLangFromUrl, pathLocalized } from "../i18n/utils";
import hero from "../data/cms/hero.json";

const lang = getLangFromUrl(Astro.url);
const c = (hero as any)[lang] ?? hero.en;
---

<section class="hero" style={`background-image: url('${hero.heroImage}');`}>
  <div class="overlay"></div>
  <div class="inner">
    <p class="eyebrow light">{c.eyebrow}</p>
    <h1>{c.titleLine1}<br />{c.titleLine2}</h1>
    <p class="lead">{c.lead}</p>
    <div class="cta">
      <a href={pathLocalized(hero.ctaPrimaryHref, lang)} class="btn-primary">{c.ctaPrimary}</a>
      <a href={pathLocalized(hero.ctaSecondaryHref, lang)} class="btn-ghost">
        {c.ctaSecondary} <i class="ti ti-arrow-right"></i>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 520px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: white;
    display: flex;
    align-items: center;
  }
  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(4, 44, 83, 0.88) 0%,
      rgba(4, 44, 83, 0.72) 55%,
      rgba(4, 44, 83, 0.55) 100%
    );
  }
  .inner {
    position: relative;
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 72px var(--section-pad-x);
  }
  .eyebrow.light { color: rgba(255, 255, 255, 0.92); }
  h1 {
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    letter-spacing: -1.2px;
    margin: 0 0 22px;
    max-width: 820px;
  }
  .lead {
    font-size: 18px;
    line-height: 1.55;
    max-width: 600px;
    margin: 0 0 32px;
    opacity: 0.92;
  }
  .cta { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
  .btn-primary,
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 13px 24px;
    border-radius: var(--radius-md);
    font-size: var(--fs-small);
    font-weight: 500;
    text-decoration: none;
    transition:
      background 0.2s ease,
      transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }
  .btn-primary {
    background: white;
    color: var(--brand);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .btn-primary:hover {
    background: var(--brand-50);
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);
  }
  .btn-ghost {
    background: transparent;
    color: white;
    border: 0.5px solid rgba(255, 255, 255, 0.6);
  }
  .btn-ghost i {
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.9);
  }
  .btn-ghost:hover i { transform: translateX(3px); }

  @media (max-width: 768px) {
    .hero { min-height: 420px; }
    .inner { padding: 56px 20px; }
    h1 { font-size: 32px; letter-spacing: -0.8px; }
    .lead { font-size: 16px; }
  }
</style>
