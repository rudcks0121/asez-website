---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import ComingSoon from "../../components/ComingSoon.astro";
import CtaBanner from "../../components/CtaBanner.astro";

const categories = [
  { icon: "ti-file-text", title: "연간 보고서", desc: "한 해의 활동, 재정, 임팩트를 정리한 연간 보고서." },
  { icon: "ti-chart-line", title: "SDG 진행 상황", desc: "UN 지속가능 개발목표(SDG) 17개에 대한 ASEZ의 기여." },
  { icon: "ti-search", title: "리서치 & 브리프", desc: "환경, 교육, 청년 참여에 관한 현장 연구." },
  { icon: "ti-scale", title: "정책 보고서", desc: "UN, 각국 정부, 협력 기관에 제출한 정책 제안." },
];

const all = await getCollection("reports", ({ data }) => !data.draft);
const reports = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) => d.toLocaleDateString("ko-KR", { year: "numeric", month: "long" });
const koType = (t: string) => ({
  "Annual report": "연간 보고서",
  "SDG progress": "SDG 진행 상황",
  "Research brief": "리서치 브리프",
  "Policy paper": "정책 보고서",
} as Record<string, string>)[t] || t;
---

<BaseLayout lang="kr" title="보고서 — ASEZ" description="ASEZ의 연간 보고서, SDG 진행 상황, 연구, 정책 보고서.">
  <Header />
  <PageHero
    eyebrow="인사이트"
    icon="ti-file-text"
    title="보고서 & 연구."
    lead="활동을 기록하고, 임팩트를 측정하고, 배운 것을 공유합니다 — 다른 사람들이 이어 갈 수 있도록."
  />
  <main>
    <section class="categories reveal">
      <div class="inner">
        <div class="grid">
          {categories.map((c) => (
            <div class="cat">
              <i class={`ti ${c.icon} icon`}></i>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="latest reveal">
      <div class="inner">
        <div class="head">
          <div>
            <p class="eyebrow">최신 발간</p>
            <h2>최근 발간된 보고서.</h2>
          </div>
          <a href="#" class="view-all">전체 보기 <i class="ti ti-arrow-right"></i></a>
        </div>
        <div class="list">
          {reports.map((r) => (
            <article class="report">
              <div class="report-main">
                <span class="pill" style={`background: ${r.data.pillBg}; color: ${r.data.pillColor};`}>{koType(r.data.type)}</span>
                <h3>{r.data.title}</h3>
                <p>{r.data.excerpt}</p>
                <div class="meta">
                  <span><i class="ti ti-calendar"></i> {fmt(r.data.date)}</span>
                  <span><i class="ti ti-file"></i> {r.data.pages}쪽</span>
                </div>
              </div>
              <a class="download" href={r.data.pdfUrl} aria-label={`Download ${r.data.title}`}
                target={r.data.pdfUrl !== "#" ? "_blank" : undefined}
                rel={r.data.pdfUrl !== "#" ? "noopener" : undefined}>
                <i class="ti ti-download"></i><span>PDF</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <CtaBanner variant="newsletter" />
    <ComingSoon message="실제 PDF 파일, 연구 데이터베이스, 연도별 아카이브가 곧 공개됩니다." />
  </main>
  <Footer />
</BaseLayout>

<style>
  .categories { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-primary); }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .categories .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
  .cat { padding: 28px; border-radius: var(--radius-lg); border: 0.5px solid var(--border); background: var(--bg-secondary); transition: border-color 0.2s, transform 0.3s; }
  .cat:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .icon { font-size: 28px; color: var(--brand); margin-bottom: 14px; display: inline-block; transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .cat:hover .icon { transform: scale(1.15) rotate(-6deg); }
  .cat h3 { font-size: var(--fs-h3); margin: 0 0 8px; line-height: var(--lh-snug); }
  .cat p { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.55; margin: 0; }

  .latest { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-secondary); border-top: 0.5px solid var(--border); }
  .head { display: flex; align-items: end; justify-content: space-between; margin-bottom: 32px; flex-wrap: wrap; gap: 16px; }
  .head h2 { font-size: var(--fs-h2); margin: 0; letter-spacing: -0.4px; }
  .view-all { font-size: var(--fs-small); color: var(--brand); text-decoration: none; font-weight: 500; }
  .list { display: flex; flex-direction: column; gap: 14px; }
  .report { display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: center; padding: 26px 28px; border-radius: var(--radius-lg); border: 0.5px solid var(--border); background: var(--bg-primary); transition: border-color 0.2s; }
  .report:hover { border-color: var(--border-strong); }
  .pill { display: inline-block; font-size: var(--fs-caption); font-weight: 500; padding: 4px 12px; border-radius: var(--radius-pill); margin-bottom: 10px; }
  .report h3 { font-size: 18px; margin: 0 0 8px; line-height: var(--lh-snug); letter-spacing: -0.2px; }
  .report > .report-main > p { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.55; margin: 0 0 12px; }
  .meta { display: flex; gap: 18px; font-size: var(--fs-caption); color: var(--text-tertiary); flex-wrap: wrap; }
  .meta i { margin-right: 4px; }
  .download { display: inline-flex; align-items: center; gap: 8px; padding: 12px 18px; border-radius: var(--radius-md); border: 0.5px solid var(--border-strong); background: var(--bg-secondary); color: var(--text-primary); text-decoration: none; font-size: var(--fs-small); font-weight: 500; transition: all 0.2s; }
  .download:hover { background: var(--brand); color: white; border-color: var(--brand); transform: translateY(-1px); }
  .download i { font-size: 16px; }

  @media (max-width: 768px) {
    .categories { padding: 56px 20px; }
    .categories .grid { grid-template-columns: 1fr; }
    .latest { padding: 56px 20px; }
    .report { grid-template-columns: 1fr; gap: 16px; padding: 22px; }
    .download { justify-self: flex-start; }
  }
</style>
