---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import PageHero from "../../../components/PageHero.astro";
import Footer from "../../../components/Footer.astro";
import ComingSoon from "../../../components/ComingSoon.astro";
import CtaBanner from "../../../components/CtaBanner.astro";

const steps = [
  { num: "1", title: "캠퍼스 챕터 찾기", desc: "ASEZ는 전 세계 7,500개 대학에 챕터가 있습니다. 문의 페이지나 지역 사무소를 통해 가까운 챕터를 안내받으세요." },
  { num: "2", title: "코디네이터에게 연락", desc: "짧은 소개를 보내주세요 — 소속 대학, ASEZ에 관심 갖게 된 계기, 가장 관심 있는 활동 분야." },
  { num: "3", title: "첫 모임 참석", desc: "기존 멤버들을 만나고, 진행 중인 프로젝트를 소개받고, 참여할 활동을 선택하세요." },
];

const benefits = [
  { icon: "ti-world", text: "전 세계 175개국 7,500개 캠퍼스의 글로벌 네트워크" },
  { icon: "ti-bolt", text: "말이 아닌 진짜 행동 — 보여주기식 인식 캠페인 X" },
  { icon: "ti-school", text: "무료 가입 — 대학생이면 누구나" },
  { icon: "ti-users", text: "평생의 동료 멘토 네트워크" },
];
---

<BaseLayout
  lang="ko"
  title="ASEZ 가입 — ASEZ"
  description="대학생이라면 누구나 ASEZ 챕터에 가입할 수 있습니다 — 가까운 팀을 찾거나 새 팀을 만들어 보세요."
>
  <Header />
  <PageHero
    eyebrow="함께하기"
    icon="ti-school"
    title="ASEZ 가입."
    lead="대학생이라면 가까운 캠퍼스 챕터를 찾아 멤버가 되어보세요. 전 세계 7,500개 협력 캠퍼스의 학생 누구나 참여할 수 있습니다."
  />
  <main>
    <section class="steps reveal">
      <div class="inner">
        <p class="eyebrow">가입 절차</p>
        <h2>첫 모임까지 3단계.</h2>
        <div class="grid">
          {steps.map((s) => (
            <div class="step">
              <div class="num">{s.num}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="benefits reveal">
      <div class="inner">
        <p class="eyebrow">멤버가 머무는 이유</p>
        <h2>가입했을 때 얻는 것들.</h2>
        <div class="grid">
          {benefits.map((b) => (
            <div class="benefit">
              <i class={`ti ${b.icon}`}></i>
              <p>{b.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CtaBanner variant="contact" />
    <ComingSoon message="검색 가능한 챕터 디렉토리와 온라인 가입 신청은 곧 공개됩니다." />
  </main>
  <Footer />
</BaseLayout>

<style>
  .steps { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-primary); }
  .benefits { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-secondary); border-top: 0.5px solid var(--border); }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  h2 { font-size: var(--fs-h2); margin: 0 0 36px; letter-spacing: -0.4px; max-width: 640px; }
  .steps .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; }
  .step { padding: 28px; border-radius: var(--radius-lg); background: var(--bg-secondary); border: 0.5px solid var(--border); transition: border-color 0.2s, transform 0.3s, box-shadow 0.3s; }
  .step:hover { border-color: var(--border-strong); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(4,44,83,0.06); }
  .num { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 50%; background: var(--brand); color: white; font-size: 22px; font-weight: 500; margin-bottom: 16px; letter-spacing: -1px; }
  .step h3 { font-size: var(--fs-h3); margin: 0 0 8px; }
  .step p { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.55; margin: 0; }
  .benefits .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
  .benefit { display: flex; align-items: center; gap: 16px; padding: 22px 24px; background: var(--bg-primary); border-radius: var(--radius-md); border: 0.5px solid var(--border); }
  .benefit i { font-size: 24px; color: var(--brand); flex-shrink: 0; }
  .benefit p { margin: 0; font-size: var(--fs-body); }
  @media (max-width: 900px) {
    .steps .grid { grid-template-columns: 1fr; }
    .benefits .grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .steps, .benefits { padding: 56px 20px; }
  }
</style>
