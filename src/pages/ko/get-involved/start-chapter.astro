---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import PageHero from "../../../components/PageHero.astro";
import Footer from "../../../components/Footer.astro";
import ComingSoon from "../../../components/ComingSoon.astro";
---

<BaseLayout
  lang="ko"
  title="챕터 만들기 — ASEZ"
  description="캠퍼스에 ASEZ 챕터가 없다면, 새로 만들어 보세요. 우리가 도와드립니다."
>
  <Header />
  <PageHero
    eyebrow="함께하기"
    icon="ti-flag"
    title="ASEZ 챕터 만들기."
    lead="캠퍼스에 챕터가 없으신가요? ASEZ는 새 챕터 설립자에게 운영 가이드, 지역 멘토십, 글로벌 동료 네트워크를 지원합니다."
  />
  <main>
    <ComingSoon message="신규 챕터 신청 절차 — 설립자 가이드와 90일 런치 플랜 — 가 마무리 단계입니다. 문의 페이지로 연락 주시면 시작을 도와드립니다." />
  </main>
  <Footer />
</BaseLayout>
