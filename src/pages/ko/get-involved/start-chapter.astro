---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import PageHero from "../../../components/PageHero.astro";
import Footer from "../../../components/Footer.astro";
import ComingSoon from "../../../components/ComingSoon.astro";
import CtaBanner from "../../../components/CtaBanner.astro";

const steps = [
  { num: "1", title: "3~5명 창립 멤버 모으기", desc: "ASEZ 챕터는 작은 창립 팀으로 시작할 때 가장 잘 작동합니다. 학과를 넘어 가치를 공유하는 친구들을 모으세요." },
  { num: "2", title: "신규 챕터 신청서 제출", desc: "캠퍼스, 창립 멤버, 가장 다루고 싶은 이슈를 알려주세요. 7일 이내 검토합니다." },
  { num: "3", title: "지역 멘토와 매칭", desc: "지역의 경험 있는 챕터 코디네이터가 첫 90일을 안내합니다 — 캠퍼스 승인, 첫 행사, 멤버 모집까지." },
  { num: "4", title: "첫 활동 런치", desc: "대부분의 신규 챕터는 첫 분기 안에 작은 나무 심기, 정화 활동, 또는 포럼을 진행합니다. 플레이북은 준비되어 있습니다." },
];

const support = [
  { icon: "ti-book", title: "설립자 가이드북", desc: "이미 챕터를 만든 곳들이 정리한 단계별 런치 플레이북." },
  { icon: "ti-users", title: "동료 네트워크", desc: "가까운 챕터와 직접 연결 — 조언과 공동 행사 가능." },
  { icon: "ti-presentation", title: "교육 자료", desc: "워크숍 템플릿, 캠페인 키트, 발표 자료." },
  { icon: "ti-shield-check", title: "브랜드 자산", desc: "로고, 폰트, 사진 라이브러리 — 바로 사용 가능." },
];
---

<BaseLayout
  lang="ko"
  title="챕터 만들기 — ASEZ"
  description="캠퍼스에 ASEZ 챕터가 없다면, 새로 만들어 보세요. 우리가 도와드립니다."
>
  <Header />
  <PageHero
    eyebrow="함께하기"
    icon="ti-flag"
    title="ASEZ 챕터 만들기."
    lead="캠퍼스에 챕터가 없으신가요? ASEZ는 새 챕터 설립자에게 운영 가이드, 지역 멘토십, 글로벌 동료 네트워크를 지원합니다."
  />
  <main>
    <section class="steps reveal">
      <div class="inner">
        <p class="eyebrow">설립 절차</p>
        <h2>런치일까지 4단계.</h2>
        <div class="grid">
          {steps.map((s) => (
            <div class="step">
              <div class="num">{s.num}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="support reveal">
      <div class="inner">
        <p class="eyebrow">우리가 제공하는 지원</p>
        <h2>맨바닥부터 시작하지 않아도 됩니다.</h2>
        <div class="grid">
          {support.map((b) => (
            <div class="card">
              <i class={`ti ${b.icon}`}></i>
              <h3>{b.title}</h3>
              <p>{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CtaBanner variant="contact" />
    <ComingSoon message="신규 챕터 신청 폼이 마무리 단계입니다. 우선은 문의 페이지로 연락 주세요." />
  </main>
  <Footer />
</BaseLayout>

<style>
  .steps { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-primary); }
  .support { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-secondary); border-top: 0.5px solid var(--border); }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  h2 { font-size: var(--fs-h2); margin: 0 0 36px; letter-spacing: -0.4px; max-width: 640px; }
  .steps .grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; }
  .step { padding: 24px; border-radius: var(--radius-lg); background: var(--bg-secondary); border: 0.5px solid var(--border); transition: border-color 0.2s, transform 0.3s; }
  .step:hover { border-color: var(--border-strong); transform: translateY(-3px); }
  .num { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: var(--brand); color: white; font-size: 18px; font-weight: 500; margin-bottom: 14px; }
  .step h3 { font-size: 16px; margin: 0 0 6px; line-height: 1.3; }
  .step p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; margin: 0; }
  .support .grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; }
  .card { padding: 24px; background: var(--bg-primary); border-radius: var(--radius-md); border: 0.5px solid var(--border); }
  .card i { font-size: 28px; color: var(--brand); margin-bottom: 12px; display: inline-block; }
  .card h3 { font-size: var(--fs-h3); margin: 0 0 6px; }
  .card p { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.5; margin: 0; }
  @media (max-width: 900px) {
    .steps .grid, .support .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .steps, .support { padding: 56px 20px; }
    .steps .grid, .support .grid { grid-template-columns: 1fr; }
  }
</style>
