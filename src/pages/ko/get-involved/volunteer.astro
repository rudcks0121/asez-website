---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import PageHero from "../../../components/PageHero.astro";
import Footer from "../../../components/Footer.astro";
import ComingSoon from "../../../components/ComingSoon.astro";
---

<BaseLayout
  lang="ko"
  title="자원봉사 참여 — ASEZ"
  description="모든 연령대에 열려 있습니다. 지역 정화 활동, 포럼, 캠페인에 참여해 보세요."
>
  <Header />
  <PageHero
    eyebrow="함께하기"
    title="ASEZ 자원봉사."
    lead="대학생이 아니어도 좋습니다 — 나무 심기, 플라스틱 정화, 재해 구호, 지역 포럼에 모든 연령대의 자원봉사자를 환영합니다."
  />
  <main>
    <ComingSoon message="가까운 행사 찾기와 일회성 봉사 신청 페이지는 곧 공개됩니다. 우선은 문의 페이지로 연락 주시면 다음 활동에 연결해 드립니다." />
  </main>
  <Footer />
</BaseLayout>
