---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import PageHero from "../../../components/PageHero.astro";
import Footer from "../../../components/Footer.astro";
import ComingSoon from "../../../components/ComingSoon.astro";
---

<BaseLayout
  lang="ko"
  title="협력 제안 — ASEZ"
  description="정부, 대학, NGO, 기업의 SDG 협력 제안 환영."
>
  <Header />
  <PageHero
    eyebrow="함께하기"
    title="ASEZ와 협력하기."
    lead="ASEZ는 UN 기관, 정부, 대학, 글로벌 NGO 등 80여 기관과 MOU를 체결했습니다. UN SDG에 부합하는 새로운 협력을 환영합니다."
  />
  <main>
    <ComingSoon message="협력 제안 폼과 제안서 템플릿이 준비 중입니다. 즉시 제안하시려면 문의 페이지를 통해 partners@asez.org로 연락 주세요." />
  </main>
  <Footer />
</BaseLayout>
