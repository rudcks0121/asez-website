---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import Stats from "../../components/Stats.astro";
import ComingSoon from "../../components/ComingSoon.astro";

const savePillars = [
  { letter: "S", title: "사회 봉사", desc: "지역사회와 함께하는 봉사 — 환경 정화, 어르신 돌봄, 학교 지원.", bg: "var(--teal-100)", color: "var(--teal-900)" },
  { letter: "A", title: "인식 개선", desc: "포럼, 세미나, 캠페인을 통해 인식을 행동으로 바꿉니다.", bg: "var(--brand-100)", color: "var(--brand-900)" },
  { letter: "V", title: "재해 구호", desc: "재해 지역에서의 긴급 대응과 장기 회복 활동.", bg: "var(--amber-100)", color: "var(--amber-900)" },
  { letter: "E", title: "환경 보호", desc: "기후 행동, 플라스틱 프리 캠페인, 나무 심기, 해안 보호.", bg: "var(--brand-400)", color: "#ffffff" },
];

const awards = [
  { year: "2024", title: "UNCCD 사무총장상", body: "UN 사막화방지협약으로부터 받은 표창 — 나무 심기 및 토지 복원 활동을 인정받음.", img: "/images/award-unccd.png" },
  { year: "2023", title: "미국 대통령 봉사상", body: "미국 내 ASEZ 챕터의 지속적이고 탁월한 봉사 활동에 수여.", img: "/images/award-us-president.png" },
  { year: "2022", title: "Green Apple & Green World Awards", body: "기후 및 플라스틱 프리 캠페인을 인정받은 국제 환경 부문 수상.", img: "/images/award-green.png" },
];
---

<BaseLayout
  lang="kr"
  title="소개 — ASEZ"
  description="ASEZ는 전 세계 175개국에서 활동하는 대학생 봉사단입니다. S.A.V.E 프레임워크를 통해 더 살기 좋은 지구를 만들어 갑니다."
>
  <Header />
  <PageHero
    eyebrow="ASEZ 소개"
    title="대학생들이 만들어가는 더 살기 좋은 지구."
    lead="ASEZ — Save the Earth from A to Z — 는 전 세계 175개국 7,500여 캠퍼스에서 활동하는 하나님의교회 대학생 봉사단 글로벌 네트워크입니다."
  />
  <main>
    <Stats />

    <section class="mission reveal">
      <div class="inner">
        <p class="eyebrow">미션</p>
        <h2>다음 세대를 위한 더 살기 좋은 지구를 남깁니다.</h2>
        <p class="lead">
          ASEZ는 수많은 청년들의 작은 행동이 모여 미래를 다시 쓸 수 있다고 믿습니다.
          전 세계 대학생들이 함께 우리 시대의 가장 시급한 환경·사회·인도적 문제에
          맞서 — 누구의 허락도 기다리지 않고 — 행동합니다.
        </p>
      </div>
    </section>

    <section class="save reveal">
      <div class="inner">
        <p class="eyebrow">S.A.V.E 운동</p>
        <h2>네 가지 기둥. 하나의 운동.</h2>
        <p class="intro">ASEZ의 모든 활동은 네 가지 영역을 중심으로 조직됩니다 — 함께 S.A.V.E 프레임워크를 이룹니다.</p>
        <div class="grid">
          {savePillars.map((pl) => (
            <div class="pillar">
              <div class="badge" style={`background: ${pl.bg}; color: ${pl.color};`}>{pl.letter}</div>
              <h3>{pl.title}</h3>
              <p>{pl.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="awards reveal">
      <div class="inner">
        <p class="eyebrow">수상 및 인정</p>
        <h2>수상 내역.</h2>
        <p class="intro">UN, 각국 정부, 국제 환경 기구로부터 받은 인정.</p>
        <div class="grid">
          {awards.map((a) => (
            <article class="award">
              <div class="img-wrap"><img src={a.img} alt={a.title} loading="lazy" /></div>
              <div class="body">
                <p class="year">{a.year}</p>
                <h3>{a.title}</h3>
                <p>{a.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <ComingSoon message="우리의 이야기(연혁)와 파트너 디렉토리는 곧 공개됩니다." />
  </main>
  <Footer />
</BaseLayout>

<style>
  .mission { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-primary); border-top: 0.5px solid var(--border); }
  .mission .inner { max-width: var(--max-width); margin: 0 auto; }
  .mission h2 { font-size: 32px; line-height: 1.2; margin: 0 0 24px; max-width: 820px; letter-spacing: -0.6px; }
  .mission .lead { font-size: 17px; color: var(--text-secondary); line-height: 1.65; max-width: 740px; }

  .save { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-secondary); border-top: 0.5px solid var(--border); }
  .save .inner { max-width: var(--max-width); margin: 0 auto; }
  .save h2 { font-size: var(--fs-h2); margin: 0 0 14px; letter-spacing: -0.4px; }
  .save .intro { font-size: var(--fs-body); color: var(--text-secondary); line-height: 1.6; max-width: 640px; margin: 0 0 40px; }
  .save .grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 18px; }
  .pillar { padding: 26px; border-radius: var(--radius-lg); background: var(--bg-primary); border: 0.5px solid var(--border); transition: border-color 0.2s, transform 0.3s, box-shadow 0.3s; }
  .pillar:hover { border-color: var(--border-strong); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(4, 44, 83, 0.06); }
  .badge { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: var(--radius-md); font-size: 22px; font-weight: 500; margin-bottom: 18px; letter-spacing: -1px; }
  .pillar h3 { font-size: var(--fs-h3); margin: 0 0 8px; line-height: var(--lh-snug); }
  .pillar p { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.55; margin: 0; }

  .awards { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-primary); border-top: 0.5px solid var(--border); }
  .awards .inner { max-width: var(--max-width); margin: 0 auto; }
  .awards h2 { font-size: var(--fs-h2); margin: 0 0 14px; letter-spacing: -0.4px; }
  .awards .intro { font-size: var(--fs-body); color: var(--text-secondary); line-height: 1.6; max-width: 680px; margin: 0 0 40px; }
  .awards .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; }
  .award { border-radius: var(--radius-lg); overflow: hidden; border: 0.5px solid var(--border); background: var(--bg-primary); transition: border-color 0.2s, transform 0.3s, box-shadow 0.3s; }
  .award:hover { border-color: var(--border-strong); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(4, 44, 83, 0.08); }
  .img-wrap { aspect-ratio: 4/3; overflow: hidden; background: var(--bg-secondary); position: relative; }
  .img-wrap img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; padding: 28px; }
  .award .body { padding: 22px 24px 24px; }
  .award .year { font-size: var(--fs-caption); color: var(--brand); font-weight: 500; letter-spacing: 1.5px; margin: 0 0 8px; }
  .award h3 { font-size: 17px; margin: 0 0 10px; line-height: var(--lh-snug); }
  .award p { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.55; margin: 0; }

  @media (max-width: 900px) {
    .save .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .awards .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .mission, .save, .awards { padding: 56px 20px; }
    .mission h2 { font-size: 26px; }
    .save .grid, .awards .grid { grid-template-columns: 1fr; }
  }
</style>
