---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import Stats from "../components/Stats.astro";
import ComingSoon from "../components/ComingSoon.astro";

const savePillars = [
  {
    letter: "S",
    title: "Social service",
    desc: "Volunteering with local communities — clean-ups, elderly care, school support.",
    bg: "var(--teal-100)",
    color: "var(--teal-900)",
  },
  {
    letter: "A",
    title: "Awareness",
    desc: "Forums, seminars, and campaigns that turn knowledge into action.",
    bg: "var(--brand-100)",
    color: "var(--brand-900)",
  },
  {
    letter: "V",
    title: "Victim relief",
    desc: "Emergency response and long-term recovery in disaster-affected regions.",
    bg: "var(--amber-100)",
    color: "var(--amber-900)",
  },
  {
    letter: "E",
    title: "Environmental",
    desc: "Climate action, plastic-free campaigns, tree planting, coastal protection.",
    bg: "var(--brand-400)",
    color: "#ffffff",
  },
];

const awards = [
  {
    year: "2024",
    title: "UNCCD Executive Secretary's Award",
    body: "Recognized by the UN Convention to Combat Desertification for our tree-planting and land restoration work.",
    img: "/images/award-unccd.png",
  },
  {
    year: "2023",
    title: "U.S. President's Volunteer Service Award",
    body: "Awarded to ASEZ chapters in the United States for sustained, exceptional volunteer service.",
    img: "/images/award-us-president.png",
  },
  {
    year: "2022",
    title: "Green Apple & Green World Awards",
    body: "International environmental awards recognizing our climate and plastic-free campaigns.",
    img: "/images/award-green.png",
  },
];
---

<BaseLayout
  title="About — ASEZ"
  description="ASEZ is a global network of university student volunteers active in 175 countries, working through the S.A.V.E framework to leave a more livable Earth."
>
  <Header />
  <PageHero
    eyebrow="About ASEZ"
    title="University students, building a more livable Earth."
    lead="ASEZ — Save the Earth from A to Z — is a global network of Church of God university student volunteers active across 175 countries and 7,500 campuses."
  />
  <main>
    <Stats />

    <!-- Mission -->
    <section class="mission reveal">
      <div class="inner">
        <p class="eyebrow">Mission</p>
        <h2>Leaving a more livable Earth for the next generation.</h2>
        <p class="lead">
          ASEZ believes that small actions, repeated by millions of young
          people, can rewrite the future. We organize university students
          worldwide to confront the most urgent environmental, social,
          and humanitarian challenges of our time — and to do so without
          waiting for permission.
        </p>
      </div>
    </section>

    <!-- S.A.V.E framework -->
    <section class="save reveal">
      <div class="inner">
        <p class="eyebrow">The S.A.V.E movement</p>
        <h2>Four pillars. One movement.</h2>
        <p class="intro">
          All ASEZ activities fall under one of four pillars — together
          they form the S.A.V.E framework, the spine of everything we do.
        </p>
        <div class="grid">
          {savePillars.map((p) => (
            <div class="pillar">
              <div class="badge" style={`background: ${p.bg}; color: ${p.color};`}>
                {p.letter}
              </div>
              <h3>{p.title}</h3>
              <p>{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Awards -->
    <section class="awards reveal">
      <div class="inner">
        <p class="eyebrow">Recognition</p>
        <h2>Awards & honors.</h2>
        <p class="intro">
          Our work has been recognized by the United Nations, national
          governments, and international environmental bodies.
        </p>
        <div class="grid">
          {awards.map((a) => (
            <article class="award">
              <div class="img-wrap">
                <img src={a.img} alt={a.title} loading="lazy" />
              </div>
              <div class="body">
                <p class="year">{a.year}</p>
                <h3>{a.title}</h3>
                <p>{a.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <ComingSoon
      message="Our story (timeline) and full Partners directory are coming soon."
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Mission */
  .mission {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .mission .inner { max-width: var(--max-width); margin: 0 auto; }
  .mission h2 {
    font-size: 32px;
    line-height: 1.2;
    margin: 0 0 24px;
    max-width: 820px;
    letter-spacing: -0.6px;
  }
  .mission .lead {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 740px;
  }

  /* S.A.V.E */
  .save {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .save .inner { max-width: var(--max-width); margin: 0 auto; }
  .save h2 {
    font-size: var(--fs-h2);
    margin: 0 0 14px;
    letter-spacing: -0.4px;
  }
  .save .intro {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 640px;
    margin: 0 0 40px;
  }
  .save .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }
  .pillar {
    padding: 26px;
    border-radius: var(--radius-lg);
    background: var(--bg-primary);
    border: 0.5px solid var(--border);
    transition:
      border-color 0.2s,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease;
  }
  .pillar:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(4, 44, 83, 0.06);
  }
  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    font-size: 22px;
    font-weight: 500;
    margin-bottom: 18px;
    letter-spacing: -1px;
  }
  .pillar h3 {
    font-size: var(--fs-h3);
    margin: 0 0 8px;
    line-height: var(--lh-snug);
  }
  .pillar p {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  /* Awards */
  .awards {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .awards .inner { max-width: var(--max-width); margin: 0 auto; }
  .awards h2 {
    font-size: var(--fs-h2);
    margin: 0 0 14px;
    letter-spacing: -0.4px;
  }
  .awards .intro {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 680px;
    margin: 0 0 40px;
  }
  .awards .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }
  .award {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 0.5px solid var(--border);
    background: var(--bg-primary);
    transition:
      border-color 0.2s,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease;
  }
  .award:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(4, 44, 83, 0.08);
  }
  .img-wrap {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--bg-secondary);
    position: relative;
  }
  .img-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 28px;
  }
  .award .body { padding: 22px 24px 24px; }
  .award .year {
    font-size: var(--fs-caption);
    color: var(--brand);
    font-weight: 500;
    letter-spacing: 1.5px;
    margin: 0 0 8px;
  }
  .award h3 {
    font-size: 17px;
    margin: 0 0 10px;
    line-height: var(--lh-snug);
  }
  .award p {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 900px) {
    .save .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .awards .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .mission, .save, .awards { padding: 56px 20px; }
    .mission h2 { font-size: 26px; }
    .save .grid,
    .awards .grid { grid-template-columns: 1fr; }
  }
</style>
