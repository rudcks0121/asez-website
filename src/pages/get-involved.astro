---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import ComingSoon from "../components/ComingSoon.astro";

const paths = [
  {
    icon: "ti-school",
    title: "Join ASEZ",
    desc: "If you're a university student, find your campus chapter and become a member.",
    href: "/get-involved/join",
  },
  {
    icon: "ti-flag",
    title: "Start a chapter",
    desc: "No ASEZ chapter on your campus yet? We'll help you start one.",
    href: "/get-involved/start-chapter",
  },
  {
    icon: "ti-hand-stop",
    title: "Volunteer with us",
    desc: "Open to community members of all ages. Join a local cleanup, forum, or campaign.",
    href: "/get-involved/volunteer",
  },
  {
    icon: "ti-building-bank",
    title: "Partner with us",
    desc: "For governments, universities, NGOs, and corporations seeking collaboration on SDGs.",
    href: "/get-involved/partner",
  },
  {
    icon: "ti-calendar-event",
    title: "Upcoming events",
    desc: "Forums, summits, and field campaigns happening this season.",
    href: "/get-involved/events",
  },
];
---

<BaseLayout
  title="Get involved — ASEZ"
  description="Five ways to be part of ASEZ — as a student member, volunteer, partner organization, or event attendee."
>
  <Header />
  <PageHero
    eyebrow="Take part"
    title="Get involved."
    lead="There are many ways to join the movement — as a student, a volunteer, a partner organization, or a participant in our forums and field campaigns."
  />
  <main>
    <section class="paths reveal">
      <div class="inner">
        <div class="grid">
          {paths.map((p) => (
            <a class="path" href={p.href}>
              <i class={`ti ${p.icon} icon`}></i>
              <h3>{p.title}</h3>
              <p>{p.desc}</p>
              <span class="more">
                Learn more <i class="ti ti-arrow-right"></i>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
    <ComingSoon
      message="Detailed sign-up forms and partnership inquiry pages are coming soon."
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  .paths {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }
  .path {
    display: flex;
    flex-direction: column;
    padding: 28px;
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
  }
  .path:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(4, 44, 83, 0.08);
  }
  .icon {
    font-size: 30px;
    color: var(--brand);
    margin-bottom: 16px;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .path:hover .icon { transform: scale(1.1); }
  h3 {
    font-size: var(--fs-h3);
    margin: 0 0 8px;
    line-height: var(--lh-snug);
  }
  p {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0 0 16px;
    flex: 1;
  }
  .more {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--brand);
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .paths { padding: 56px 20px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
