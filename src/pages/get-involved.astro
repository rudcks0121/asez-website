---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import ComingSoon from "../components/ComingSoon.astro";
import { pathLocalized } from "../i18n/utils";
import page from "../data/cms/page-get-involved.json";

const lang = "en" as const;
const c = page.en;
const p = (path: string) => pathLocalized(path, lang);
const paths = page.paths.map((pt: any) => ({ ...pt, ...(pt[lang] ?? pt.en) }));
const reasons = page.reasons.map((r: any) => ({ ...r, ...(r[lang] ?? r.en) }));
---

<BaseLayout title={c.title} description={c.description}>
  <Header />
  <PageHero
    eyebrow={c.hero.eyebrow}
    icon="ti-hand-stop"
    title={c.hero.title}
    lead={c.hero.lead}
  />
  <main>
    <section class="paths reveal">
      <div class="inner">
        <div class="grid">
          {paths.map((pt: any) => (
            <a class="path" href={p(pt.href)}>
              <i class={`ti ${pt.icon} icon`}></i>
              <h3>{pt.title}</h3>
              <p>{pt.desc}</p>
              <span class="more">
                {c.paths.learnMore} <i class="ti ti-arrow-right"></i>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="why reveal">
      <div class="inner">
        <p class="eyebrow">{c.why.eyebrow}</p>
        <h2>{c.why.title}</h2>
        <p class="intro">{c.why.intro}</p>
        <div class="grid">
          {reasons.map((r: any) => (
            <div class="reason">
              <i class={`ti ${r.icon} icon`}></i>
              <h3>{r.title}</h3>
              <p>{r.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="signup reveal">
      <div class="inner">
        <div class="signup-card">
          <div class="copy">
            <p class="eyebrow light">{c.signup.eyebrow}</p>
            <h2>{c.signup.title}</h2>
            <p class="desc">{c.signup.desc}</p>
          </div>
          <form class="form" onsubmit="event.preventDefault();">
            <label>
              <span>{c.signup.emailLabel}</span>
              <input type="email" placeholder={c.signup.emailPlaceholder} required />
            </label>
            <label>
              <span>{c.signup.campusLabel}</span>
              <input type="text" placeholder={c.signup.campusPlaceholder} required />
            </label>
            <button type="submit" class="submit">
              {c.signup.submit} <i class="ti ti-arrow-right"></i>
            </button>
            <p class="fine">{c.signup.fine}</p>
          </form>
        </div>
      </div>
    </section>

    <ComingSoon message={c.comingSoon} />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* === Paths grid === */
  .paths {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .paths .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }
  .path {
    display: flex;
    flex-direction: column;
    padding: 28px;
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-primary);
    text-decoration: none;
    transition:
      border-color 0.2s,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease;
  }
  .path:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(4, 44, 83, 0.08);
  }
  .icon {
    font-size: 30px;
    color: var(--brand);
    margin-bottom: 16px;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .path:hover .icon { transform: scale(1.1); }
  .path h3 {
    font-size: var(--fs-h3);
    margin: 0 0 8px;
    line-height: var(--lh-snug);
  }
  .path p {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0 0 16px;
    flex: 1;
  }
  .more {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--brand);
  }

  /* === Why ASEZ === */
  .why {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .why h2 {
    font-size: var(--fs-h2);
    margin: 0 0 14px;
    letter-spacing: -0.4px;
  }
  .why .intro {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 640px;
    margin: 0 0 40px;
  }
  .why .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }
  .reason {
    padding: 26px;
    border-radius: var(--radius-lg);
    background: var(--bg-primary);
    border: 0.5px solid var(--border);
  }
  .reason .icon {
    font-size: 26px;
    color: var(--brand);
    margin-bottom: 16px;
    display: inline-block;
  }
  .reason h3 {
    font-size: var(--fs-h3);
    margin: 0 0 8px;
    line-height: var(--lh-snug);
  }
  .reason p {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  /* === Sign-up === */
  .signup {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .signup-card {
    max-width: var(--max-width);
    margin: 0 auto;
    background: var(--brand-darker);
    color: white;
    border-radius: var(--radius-lg);
    padding: 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
    background-image: linear-gradient(
      135deg,
      var(--brand-darker) 0%,
      var(--brand-dark) 100%
    );
  }
  .copy .eyebrow.light { color: rgba(255, 255, 255, 0.7); }
  .copy h2 {
    font-size: 30px;
    line-height: 1.15;
    margin: 0 0 16px;
    letter-spacing: -0.6px;
  }
  .copy .desc {
    font-size: var(--fs-body);
    opacity: 0.85;
    line-height: 1.6;
    margin: 0;
  }
  .form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form label span {
    font-size: var(--fs-caption);
    letter-spacing: 1px;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .form input {
    background: rgba(255, 255, 255, 0.08);
    border: 0.5px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    font-size: var(--fs-body);
    color: white;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .form input::placeholder { color: rgba(255, 255, 255, 0.35); }
  .form input:focus {
    border-color: var(--brand-400);
    background: rgba(255, 255, 255, 0.12);
  }
  .submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: white;
    color: var(--brand);
    border: none;
    border-radius: var(--radius-md);
    padding: 12px 22px;
    font-size: var(--fs-small);
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition:
      transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s;
    margin-top: 4px;
  }
  .submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.2);
  }
  .submit i { transition: transform 0.2s; }
  .submit:hover i { transform: translateX(3px); }
  .fine {
    font-size: 12px;
    opacity: 0.55;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  /* === Responsive === */
  @media (max-width: 900px) {
    .paths .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .why .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .signup-card { grid-template-columns: 1fr; gap: 32px; padding: 40px; }
    .copy h2 { font-size: 26px; }
  }
  @media (max-width: 560px) {
    .paths, .why, .signup { padding: 56px 20px; }
    .paths .grid { grid-template-columns: 1fr; }
    .why .grid { grid-template-columns: 1fr; }
    .signup-card { padding: 32px 24px; }
  }
</style>
