---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StoryCard from "../../components/StoryCard.astro";

export async function getStaticPaths() {
  const issues = await getCollection("issues", ({ data }) => !data.draft);
  return issues.map((i) => ({ params: { slug: i.id }, props: { issue: i } }));
}

interface Props { issue: CollectionEntry<"issues">; }
const { issue } = Astro.props;
const { Content } = await render(issue);

// 같은 카테고리의 관련 스토리 찾기
// (issue title이 story category와 일치하는 경우)
const allStories = await getCollection("stories", ({ data }) => !data.draft);
const related = allStories
  .filter((s) => {
    const cat = s.data.category.toLowerCase();
    const title = issue.data.title.toLowerCase();
    // 매칭: "Climate Action" ↔ "Climate action", "Plastic-Free World" ↔ "Plastic-free"
    return cat === title || title.startsWith(cat) || cat.startsWith(title.split(" ")[0]);
  })
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

// 다른 5개 이슈 — 네비게이션용
const allIssues = await getCollection("issues", ({ data }) => !data.draft);
const otherIssues = allIssues
  .filter((i) => i.id !== issue.id)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title={`${issue.data.title} — ASEZ`}
  description={issue.data.summary}
  image={issue.data.image}
  type="article"
>
  <Header />

  <article class="issue-page">
    <!-- Page hero with color block -->
    <section class="hero" style={`background: ${issue.data.bg};`}>
      <div class="inner">
        <a href="/what-we-do" class="back">
          <i class="ti ti-arrow-left"></i> All issues
        </a>
        <i class={`ti ${issue.data.icon} hero-icon`} style={`color: ${issue.data.iconColor};`}></i>
        <h1 style={`color: ${issue.data.iconColor};`}>{issue.data.title}</h1>
        <p class="tagline" style={`color: ${issue.data.iconColor};`}>{issue.data.tagline}</p>
      </div>
    </section>

    <!-- Summary + optional image -->
    <section class="summary reveal">
      <div class="inner">
        <p class="lead">{issue.data.summary}</p>
        {issue.data.image && (
          <div class="cover">
            <img src={issue.data.image} alt={issue.data.title} loading="lazy" />
          </div>
        )}
      </div>
    </section>

    <!-- Body (markdown) -->
    <section class="body reveal">
      <div class="inner prose">
        <Content />
      </div>
    </section>

    {related.length > 0 && (
      <section class="related reveal">
        <div class="inner">
          <p class="eyebrow">Related stories</p>
          <h2>Recent {issue.data.title.toLowerCase()} stories.</h2>
          <div class="grid">
            {related.map((r) => (
              <StoryCard
                category={r.data.category}
                title={r.data.title}
                date={fmt(r.data.date)}
                imgUrl={r.data.image}
                pillBg={r.data.pillBg}
                pillColor={r.data.pillColor}
                href={`/stories/${r.id}`}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Other issues navigation -->
    <section class="other-issues reveal">
      <div class="inner">
        <p class="eyebrow">More from our work</p>
        <h2>Other issues we tackle.</h2>
        <div class="issue-grid">
          {otherIssues.map((i) => (
            <a class="issue-card" href={`/what-we-do/${i.id}`}>
              <div class="visual" style={`background: ${i.data.bg};`}>
                <i class={`ti ${i.data.icon}`} style={`color: ${i.data.iconColor};`}></i>
              </div>
              <div class="card-body">
                <h3>{i.data.title}</h3>
                <p>{i.data.tagline}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .issue-page { background: var(--bg-primary); }

  /* Hero — color block */
  .hero {
    padding: 72px var(--section-pad-x) 80px;
    text-align: left;
  }
  .hero .inner { max-width: var(--max-width); margin: 0 auto; }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: inherit;
    opacity: 0.7;
    font-size: var(--fs-small);
    font-weight: 500;
    text-decoration: none;
    margin-bottom: 36px;
    transition: gap 0.2s, opacity 0.2s;
  }
  .back:hover { gap: 10px; opacity: 1; }
  .back i { transition: transform 0.2s; }
  .back:hover i { transform: translateX(-3px); }

  .hero-icon {
    font-size: 64px;
    margin-bottom: 22px;
    display: inline-block;
  }
  .hero h1 {
    font-size: 52px;
    line-height: 1.05;
    letter-spacing: -1.2px;
    margin: 0 0 14px;
  }
  .tagline {
    font-size: 22px;
    line-height: 1.3;
    opacity: 0.85;
    margin: 0;
    font-weight: 500;
  }

  /* Summary */
  .summary {
    padding: 64px var(--section-pad-x) 32px;
    background: var(--bg-primary);
  }
  .summary .inner { max-width: 820px; margin: 0 auto; }
  .lead {
    font-size: 20px;
    line-height: 1.55;
    color: var(--text-primary);
    margin: 0 0 36px;
    letter-spacing: -0.2px;
  }
  .cover {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16/9;
    position: relative;
  }
  .cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Body (markdown) */
  .body {
    padding: 32px var(--section-pad-x) 64px;
    background: var(--bg-primary);
  }
  .body .inner { max-width: 720px; margin: 0 auto; }
  .prose :global(p) {
    font-size: 17px;
    line-height: 1.75;
    color: var(--text-primary);
    margin: 0 0 24px;
  }
  .prose :global(p:last-child) { margin-bottom: 0; }
  .prose :global(h2) {
    font-size: 26px;
    font-weight: 500;
    margin: 44px 0 18px;
    letter-spacing: -0.4px;
  }
  .prose :global(h2:first-child) { margin-top: 0; }
  .prose :global(h3) {
    font-size: 20px;
    font-weight: 500;
    margin: 36px 0 14px;
  }
  .prose :global(ul),
  .prose :global(ol) {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-primary);
    margin: 0 0 24px;
    padding-left: 22px;
  }
  .prose :global(li) { margin-bottom: 10px; }
  .prose :global(strong) { font-weight: 500; color: var(--text-primary); }
  .prose :global(a) {
    color: var(--brand);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--brand);
    padding: 4px 0 4px 22px;
    margin: 32px 0;
    font-size: 19px;
    line-height: 1.55;
  }

  /* Related stories */
  .related {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .related .inner { max-width: var(--max-width); margin: 0 auto; }
  .related h2 {
    font-size: var(--fs-h2);
    margin: 0 0 36px;
    letter-spacing: -0.4px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  /* Other issues navigation */
  .other-issues {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .other-issues .inner { max-width: var(--max-width); margin: 0 auto; }
  .other-issues h2 {
    font-size: var(--fs-h2);
    margin: 0 0 36px;
    letter-spacing: -0.4px;
  }
  .issue-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
  }
  .issue-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 0.5px solid var(--border);
    background: var(--bg-primary);
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .issue-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(4, 44, 83, 0.08);
  }
  .visual {
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .visual i {
    font-size: 32px;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .issue-card:hover .visual i {
    transform: scale(1.18) rotate(-8deg);
  }
  .card-body {
    padding: 14px 16px 16px;
  }
  .card-body h3 {
    font-size: 14px;
    margin: 0 0 4px;
    line-height: var(--lh-snug);
    letter-spacing: -0.2px;
  }
  .card-body p {
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.4;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .issue-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 768px) {
    .hero { padding: 56px 20px 64px; }
    .hero h1 { font-size: 36px; letter-spacing: -0.6px; }
    .tagline { font-size: 17px; }
    .hero-icon { font-size: 48px; }
    .summary { padding: 48px 20px 24px; }
    .lead { font-size: 17px; }
    .body { padding: 24px 20px 48px; }
    .prose :global(p),
    .prose :global(ul),
    .prose :global(ol) { font-size: 16px; }
    .related, .other-issues { padding: 56px 20px; }
    .grid { grid-template-columns: 1fr; }
    .issue-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
