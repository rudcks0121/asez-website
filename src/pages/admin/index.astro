---
// Decap CMS bootstrap + 라이브 사이트 미리보기 iframe.
// config.yml은 /public/admin/config.yml에 있어 /admin/config.yml로 fetch됨.
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="cms-config-url" type="text/yaml" href="/admin/config.yml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"
    />
    <title>ASEZ 콘텐츠 관리자</title>
    <style is:inline>
      html, body { margin: 0; padding: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Inter", "Pretendard", system-ui, sans-serif; }

      /* === 페이지 레이아웃: 좌측 Decap, 우측 사이트 iframe === */
      body { display: flex; min-height: 100vh; }
      #nc-root {
        flex: 1;
        min-width: 0;
        height: 100vh;
        overflow: hidden;
      }

      /* === 우측 라이브 미리보기 패널 === */
      .live-pane {
        width: 40vw;
        max-width: 720px;
        min-width: 360px;
        border-left: 1px solid rgba(4, 44, 83, 0.12);
        background: white;
        display: flex;
        flex-direction: column;
        position: sticky;
        top: 0;
        height: 100vh;
        z-index: 100;
        transition: width 0.3s ease, transform 0.3s ease;
      }
      .live-pane.collapsed {
        width: 0;
        min-width: 0;
        transform: translateX(100%);
      }
      .live-toolbar {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-bottom: 1px solid rgba(4, 44, 83, 0.08);
        background: #f8fafc;
        font-size: 13px;
      }
      .live-toolbar .title {
        font-weight: 600;
        color: #042c53;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-right: auto;
      }
      .live-toolbar .title i { font-size: 16px; color: #2060ad; }
      .live-toolbar button,
      .live-toolbar a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border: 1px solid rgba(4, 44, 83, 0.12);
        border-radius: 6px;
        background: white;
        color: #475569;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
        font-family: inherit;
        font-size: 13px;
      }
      .live-toolbar button:hover,
      .live-toolbar a:hover {
        background: #2060ad;
        color: white;
        border-color: #2060ad;
      }
      .live-toolbar button i,
      .live-toolbar a i { font-size: 14px; }
      .live-url {
        flex: 1;
        min-width: 0;
        padding: 6px 10px;
        background: white;
        border: 1px solid rgba(4, 44, 83, 0.12);
        border-radius: 6px;
        font-family: "SF Mono", Menlo, monospace;
        font-size: 12px;
        color: #475569;
        outline: none;
      }
      .live-url:focus { border-color: #2060ad; }
      .live-iframe-wrap {
        flex: 1;
        position: relative;
        background: #f1f5f9;
        overflow: hidden;
      }
      .live-iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
        background: white;
      }
      .live-hint {
        padding: 12px 14px;
        background: linear-gradient(135deg, #eff6ff, #f8fafc);
        border-bottom: 1px solid rgba(4, 44, 83, 0.06);
        font-size: 12px;
        color: #475569;
        line-height: 1.5;
      }
      .live-hint strong { color: #042c53; }

      /* === 미리보기 패널 토글 버튼 (collapsed 상태에서만 보임) === */
      .live-show {
        position: fixed;
        top: 50%;
        right: 0;
        transform: translateY(-50%);
        z-index: 99999;
        background: #2060ad;
        color: white;
        border: 0;
        padding: 12px 8px;
        border-radius: 8px 0 0 8px;
        cursor: pointer;
        font-family: inherit;
        font-size: 12px;
        writing-mode: vertical-rl;
        letter-spacing: 2px;
        box-shadow: -4px 0 12px rgba(4, 44, 83, 0.2);
        display: none;
      }
      .live-pane.collapsed + .live-show { display: block; }

      /* === 상단 도움말 toolbar === */
      .admin-toolbar {
        position: fixed;
        top: 12px;
        right: calc(40vw + 16px);
        z-index: 999999;
        display: flex;
        gap: 8px;
        align-items: center;
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(4, 44, 83, 0.12);
        border-radius: 999px;
        padding: 6px 6px 6px 14px;
        box-shadow: 0 4px 16px rgba(4, 44, 83, 0.1);
        font-size: 13px;
        transition: right 0.3s ease;
      }
      .live-pane.collapsed ~ .admin-toolbar {
        right: 16px;
      }
      .admin-toolbar .label {
        color: #2060ad;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .admin-toolbar .label i { font-size: 16px; }
      .admin-toolbar .divider {
        width: 1px; height: 18px;
        background: rgba(4, 44, 83, 0.15);
      }
      .admin-toolbar a.btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 999px;
        background: #2060ad;
        color: white;
        text-decoration: none;
        font-weight: 500;
        font-size: 12.5px;
        transition: background 0.15s, transform 0.15s;
      }
      .admin-toolbar a.btn:hover { background: #194b88; transform: translateY(-1px); }
      .admin-toolbar a.btn i { font-size: 15px; }
      .admin-toolbar a.btn-secondary {
        background: transparent;
        color: #2060ad;
        border: 1px solid rgba(32, 96, 173, 0.3);
      }
      .admin-toolbar a.btn-secondary:hover { background: rgba(32, 96, 173, 0.08); }

      @media (max-width: 1100px) {
        .live-pane { width: 50vw; min-width: 320px; }
      }
      @media (max-width: 900px) {
        body { flex-direction: column; }
        #nc-root { height: auto; min-height: 60vh; }
        .live-pane { width: 100%; max-width: none; min-width: 0; height: 50vh; position: relative; border-left: 0; border-top: 1px solid rgba(4, 44, 83, 0.12); }
        .live-pane.collapsed { height: 0; transform: translateY(100%); }
        .admin-toolbar { right: 10px; padding: 4px 4px 4px 10px; font-size: 12px; }
        .admin-toolbar .label span { display: none; }
        .admin-toolbar a.btn span { display: none; }
        .live-pane.collapsed ~ .admin-toolbar { right: 10px; }
      }
    </style>
  </head>
  <body>
    <!-- Decap CMS는 자동으로 body에 마운트되므로 다른 자식 요소가 있어도 OK.
         단, position: fixed/sticky 요소만 viewport에 떠 있게 안정적 -->
    <div id="nc-root" aria-hidden="false"></div>

    <aside class="live-pane" id="live-pane">
      <div class="live-toolbar">
        <span class="title">
          <i class="ti ti-eye"></i>
          실시간 미리보기
        </span>
        <input
          class="live-url"
          id="live-url"
          type="text"
          value="/"
          aria-label="미리보기 URL"
        />
        <a id="live-open" href="/" target="_blank" rel="noopener" title="새 창에서 열기" aria-label="새 창에서 열기">
          <i class="ti ti-external-link"></i>
        </a>
        <button id="live-refresh" type="button" title="새로고침" aria-label="새로고침">
          <i class="ti ti-refresh"></i>
        </button>
        <button id="live-collapse" type="button" title="패널 닫기" aria-label="패널 닫기">
          <i class="ti ti-x"></i>
        </button>
      </div>
      <div class="live-hint">
        <strong>편집 후 저장(게시)</strong>하면 약 1분 뒤 빌드가 끝나고 이 패널이
        자동 새로고침됩니다. 실시간 변경은 우측 패널에서 바로 보이지 않을 수 있어요.
      </div>
      <div class="live-iframe-wrap">
        <iframe
          class="live-iframe"
          id="live-iframe"
          src="/?cms=1"
          title="ASEZ 사이트 미리보기"
          loading="lazy"
        ></iframe>
      </div>
    </aside>
    <button class="live-show" id="live-show" type="button" aria-label="미리보기 패널 열기">
      미리보기 열기
    </button>

    <div class="admin-toolbar" role="toolbar" aria-label="관리자 도구">
      <span class="label" aria-hidden="true">
        <i class="ti ti-shield-lock"></i>
        <span>ASEZ 관리자</span>
      </span>
      <span class="divider"></span>
      <a class="btn" href="/admin-guide" target="_blank" rel="noopener">
        <i class="ti ti-book-2"></i>
        <span>사용 가이드</span>
      </a>
      <a class="btn btn-secondary" href="/" target="_blank" rel="noopener" aria-label="사이트 새 창에서 열기">
        <i class="ti ti-external-link"></i>
        <span>사이트 보기</span>
      </a>
    </div>

    <script
      is:inline
      src="https://unpkg.com/decap-cms@^3.4.0/dist/decap-cms.js"
    ></script>

    <!-- Decap CMS 미리보기 패널에 사이트 스타일 + 커스텀 템플릿 등록 -->
    <script is:inline>
      (function setupPreview() {
        if (!window.CMS) { setTimeout(setupPreview, 100); return; }
        const CMS = window.CMS;
        CMS.registerPreviewStyle("/admin/preview.css");

        const h = window.h || (window.React && window.React.createElement);
        if (!h) return; // h 없으면 커스텀 템플릿 등록 안 함, raw preview만 사용

        // === Story preview === //
        function StoryPreview({ entry, widgetFor }) {
          const data = entry.get("data");
          const title = data.get("title") || "(제목 없음)";
          const category = data.get("category");
          const date = data.get("date");
          const location = data.get("location");
          const image = data.get("image");
          const pillBg = data.get("pillBg") || "var(--brand-50)";
          const pillColor = data.get("pillColor") || "var(--brand-darker)";
          const fmtDate = date ? new Date(date).toLocaleDateString("en-US", {
            year: "numeric", month: "long", day: "numeric",
          }) : null;

          return h("article", { className: "story-preview" },
            h("div", { className: "cms-preview-hero" },
              category && h("span", {
                className: "pill",
                style: { background: pillBg, color: pillColor },
              }, category),
              h("h1", null, title),
              h("p", { className: "meta" },
                fmtDate && h("span", null, "📅 " + fmtDate),
                location && h("span", null, "📍 " + location),
              ),
            ),
            image && h("img", { src: image, alt: title, style: { width: "100%", aspectRatio: "16/8", objectFit: "cover", borderRadius: "8px", marginBottom: "32px" } }),
            widgetFor("body") || h("p", { className: "cms-preview-empty" }, "본문이 비어 있습니다."),
          );
        }
        CMS.registerPreviewTemplate("stories", StoryPreview);

        // === Report preview === //
        function ReportPreview({ entry, widgetFor }) {
          const data = entry.get("data");
          const title = data.get("title") || "(제목 없음)";
          const type = data.get("type");
          const date = data.get("date");
          const pages = data.get("pages");
          const excerpt = data.get("excerpt");
          const pillBg = data.get("pillBg") || "var(--brand-50)";
          const pillColor = data.get("pillColor") || "var(--brand-darker)";
          const fmtDate = date ? new Date(date).toLocaleDateString("en-US", { year: "numeric", month: "long" }) : null;

          return h("article", null,
            h("div", { className: "cms-preview-hero" },
              type && h("span", { className: "pill", style: { background: pillBg, color: pillColor } }, type),
              h("h1", null, title),
              h("p", { className: "meta" },
                fmtDate && h("span", null, "📅 " + fmtDate),
                pages && h("span", null, "📄 " + pages + "p"),
              ),
            ),
            excerpt && h("p", { style: { fontSize: "19px", color: "var(--text-secondary)", lineHeight: 1.6 } }, excerpt),
            widgetFor("body") || h("p", { className: "cms-preview-empty" }, "본문이 비어 있습니다."),
          );
        }
        CMS.registerPreviewTemplate("reports", ReportPreview);

        // === Event preview === //
        function EventPreview({ entry }) {
          const data = entry.get("data");
          const title = data.get("title") || "(제목 없음)";
          const type = data.get("type");
          const date = data.get("date");
          const endDate = data.get("endDate");
          const location = data.get("location");
          const excerpt = data.get("excerpt");
          const pillBg = data.get("pillBg") || "var(--brand-50)";
          const pillColor = data.get("pillColor") || "var(--brand-darker)";
          const fmtDate = (d) => d ? new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) : null;
          const dateStr = endDate
            ? fmtDate(date) + " — " + fmtDate(endDate)
            : fmtDate(date);

          return h("article", null,
            h("div", { className: "cms-preview-hero" },
              type && h("span", { className: "pill", style: { background: pillBg, color: pillColor } }, type),
              h("h1", null, title),
              h("p", { className: "meta" },
                dateStr && h("span", null, "📅 " + dateStr),
                location && h("span", null, "📍 " + location),
              ),
            ),
            excerpt && h("p", { style: { fontSize: "17px", lineHeight: 1.7 } }, excerpt),
          );
        }
        CMS.registerPreviewTemplate("events", EventPreview);

        // === Issue (활동) preview === //
        function IssuePreview({ entry, widgetFor }) {
          const data = entry.get("data");
          const title = data.get("title") || "(제목 없음)";
          const tagline = data.get("tagline");
          const summary = data.get("summary");

          return h("article", null,
            h("div", { className: "cms-preview-hero" },
              h("h1", null, title),
              tagline && h("p", { style: { fontSize: "20px", color: "var(--brand)", fontWeight: 500, margin: "0 0 16px" } }, tagline),
              summary && h("p", { style: { fontSize: "17px", color: "var(--text-secondary)", lineHeight: 1.65, margin: 0 } }, summary),
            ),
            widgetFor("body") || h("p", { className: "cms-preview-empty" }, "본문이 비어 있습니다."),
          );
        }
        CMS.registerPreviewTemplate("issues", IssuePreview);
      })();
    </script>

    <script is:inline>
      // === Preview Pane 토글 + URL 입력 === //
      const pane = document.getElementById("live-pane");
      const showBtn = document.getElementById("live-show");
      const collapseBtn = document.getElementById("live-collapse");
      const refreshBtn = document.getElementById("live-refresh");
      const openLink = document.getElementById("live-open");
      const urlInput = document.getElementById("live-url");
      const iframe = document.getElementById("live-iframe");

      const SAVED = "asez_cms_preview_path";
      const initialPath = localStorage.getItem(SAVED) || "/";
      urlInput.value = initialPath;
      iframe.src = appendCmsFlag(initialPath);
      openLink.href = initialPath;

      function appendCmsFlag(path) {
        if (!path.startsWith("/")) path = "/" + path;
        return path + (path.includes("?") ? "&" : "?") + "cms=1";
      }

      function loadUrl(path) {
        if (!path) path = "/";
        if (!path.startsWith("/")) path = "/" + path;
        localStorage.setItem(SAVED, path);
        iframe.src = appendCmsFlag(path);
        openLink.href = path;
        urlInput.value = path;
      }

      urlInput.addEventListener("change", () => loadUrl(urlInput.value));
      urlInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") { e.preventDefault(); loadUrl(urlInput.value); }
      });
      refreshBtn.addEventListener("click", () => {
        iframe.src = iframe.src; // force reload
      });
      collapseBtn.addEventListener("click", () => {
        pane.classList.add("collapsed");
        localStorage.setItem("asez_cms_preview_collapsed", "1");
      });
      showBtn.addEventListener("click", () => {
        pane.classList.remove("collapsed");
        localStorage.removeItem("asez_cms_preview_collapsed");
      });
      if (localStorage.getItem("asez_cms_preview_collapsed") === "1") {
        pane.classList.add("collapsed");
      }

      // === Decap CMS와 연동: 현재 편집 중인 entry의 preview_path로 자동 점프 === //
      // Decap이 마운트되면 URL 해시 변경을 감지해서 preview_path를 갱신
      function syncPathFromHash() {
        // 해시 형태: #/collections/{coll}/entries/{slug}
        const m = location.hash.match(/^#\/collections\/([^/]+)\/(?:entries\/([^/]+)|new)/);
        if (!m) return;
        const coll = m[1];
        const slug = m[2];

        // Static mapping based on config.yml preview_path
        const pathMap = {
          stories: slug ? `/stories/${slug}` : "/stories",
          reports: "/reports",
          events: "/get-involved/events",
          issues: slug ? `/what-we-do/${slug}` : "/what-we-do",
          home: "/", // file collection — handled by entry-specific paths below
          pages: null, // ditto
        };
        const filePathMap = {
          hero: "/", catchphrase: "/", stats: "/", projects: "/",
          regions: "/", recognition: "/", videos: "/", sns: "/",
          about: "/about", contact: "/contact",
          where_we_work: "/where-we-work", what_we_do: "/what-we-do",
          get_involved: "/get-involved",
          join: "/get-involved/join", start_chapter: "/get-involved/start-chapter",
          volunteer: "/get-involved/volunteer", partner: "/get-involved/partner",
        };

        let target = null;
        if (pathMap[coll] !== undefined && pathMap[coll] !== null) {
          target = pathMap[coll];
        } else if (filePathMap[slug]) {
          target = filePathMap[slug];
        }
        if (target && target !== urlInput.value) {
          loadUrl(target);
        }
      }
      window.addEventListener("hashchange", syncPathFromHash);
      // 초기 1회 (이미 entry URL로 진입한 경우)
      setTimeout(syncPathFromHash, 300);
    </script>
  </body>
</html>
