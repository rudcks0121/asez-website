---
// Decap CMS bootstrap + 토글 가능한 분할 미리보기.
// 기본은 Decap이 전체 화면, 우상단 "미리보기" 버튼으로 우측 패널 열고 닫기.
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="cms-config-url" type="text/yaml" href="/admin/config.yml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"
    />
    <title>ASEZ 콘텐츠 관리자</title>
    <style is:inline>
      :root { --preview-w: 40vw; }
      html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Inter", "Pretendard", system-ui, sans-serif;
        background: #f1f5f9;
      }

      /* === Decap 컨테이너 === */
      #nc-root {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: white;
        transition: right 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        overflow: hidden;
      }
      body.preview-open #nc-root { right: var(--preview-w); }
      /* Decap 내부 fixed 자식들을 강제로 컨테이너 안으로 — 보험용 */
      body.preview-open #nc-root > *,
      body.preview-open #nc-root > * > *[class*="AppWrapper"] {
        right: 0 !important;
        width: 100% !important;
        max-width: 100% !important;
      }

      /* === 미리보기 패널 === */
      .live-pane {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        width: var(--preview-w);
        min-width: 280px;
        max-width: 90vw;
        z-index: 100;
        background: white;
        border-left: 1px solid rgba(4, 44, 83, 0.12);
        display: flex;
        flex-direction: column;
        transform: translateX(100%);
        transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
        box-shadow: -12px 0 28px rgba(4, 44, 83, 0.08);
      }
      body.preview-open .live-pane { transform: translateX(0); }
      body.dragging .live-pane,
      body.dragging #nc-root { transition: none !important; }
      body.dragging * { user-select: none !important; }

      /* === 드래그 핸들 (Chrome DevTools 스타일) === */
      .live-resizer {
        position: absolute;
        left: -6px;
        top: 0;
        bottom: 0;
        width: 12px;
        cursor: col-resize;
        z-index: 101;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .live-resizer::before {
        content: "";
        width: 3px;
        height: 36px;
        background: rgba(4, 44, 83, 0.18);
        border-radius: 2px;
        transition: background 0.15s;
      }
      .live-resizer:hover::before,
      .live-resizer.active::before {
        background: #2060ad;
      }
      .live-resizer::after {
        content: "";
        position: absolute;
        inset: 0 5px;
        background: transparent;
        transition: background 0.15s;
      }
      .live-resizer:hover::after,
      .live-resizer.active::after {
        background: rgba(32, 96, 173, 0.12);
      }
      body.dragging .live-iframe { pointer-events: none; }

      /* === 패널 툴바 === */
      .live-toolbar {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-bottom: 1px solid rgba(4, 44, 83, 0.08);
        background: #f8fafc;
        font-size: 13px;
      }
      .live-toolbar .title {
        font-weight: 600;
        color: #042c53;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        flex-shrink: 0;
      }
      .live-toolbar .title i { font-size: 16px; color: #2060ad; }
      .live-toolbar button,
      .live-toolbar a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border: 1px solid rgba(4, 44, 83, 0.12);
        border-radius: 6px;
        background: white;
        color: #475569;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
        font-family: inherit;
        font-size: 13px;
        flex-shrink: 0;
      }
      .live-toolbar button:hover,
      .live-toolbar a:hover {
        background: #2060ad;
        color: white;
        border-color: #2060ad;
      }
      .live-toolbar button i,
      .live-toolbar a i { font-size: 14px; }

      .device-group {
        display: inline-flex;
        gap: 2px;
        background: rgba(4, 44, 83, 0.06);
        border-radius: 7px;
        padding: 2px;
        flex-shrink: 0;
      }
      .device-btn {
        width: 26px !important;
        height: 24px !important;
        border: 0 !important;
        background: transparent !important;
        color: #475569;
      }
      .device-btn:hover { background: rgba(255,255,255,0.6) !important; color: #2060ad !important; }
      .device-btn.active {
        background: white !important;
        color: #2060ad !important;
        box-shadow: 0 1px 3px rgba(4, 44, 83, 0.15);
      }
      .device-btn i { font-size: 13px !important; }

      .live-url {
        flex: 1;
        min-width: 60px;
        padding: 6px 10px;
        background: white;
        border: 1px solid rgba(4, 44, 83, 0.12);
        border-radius: 6px;
        font-family: "SF Mono", Menlo, monospace;
        font-size: 12px;
        color: #475569;
        outline: none;
      }
      .live-url:focus { border-color: #2060ad; }

      /* === iframe wrapper === */
      .live-iframe-wrap {
        flex: 1;
        position: relative;
        background: #e5e7eb;
        overflow: auto;
        display: flex;
        align-items: flex-start;
        justify-content: center;
      }
      .live-iframe {
        width: 100%;
        height: 100%;
        max-width: 100%;
        border: 0;
        background: white;
        transition: max-width 0.25s ease, height 0.25s ease, box-shadow 0.25s ease, border-radius 0.25s ease, margin 0.25s ease;
      }
      .live-iframe-wrap.device-mobile {
        padding: 16px 0;
      }
      .live-iframe-wrap.device-mobile .live-iframe {
        max-width: 390px;
        height: calc(100% - 32px);
        box-shadow: 0 0 0 8px #1f2937, 0 12px 36px rgba(0, 0, 0, 0.25);
        border-radius: 24px;
      }
      .live-iframe-wrap.device-tablet {
        padding: 16px 0;
      }
      .live-iframe-wrap.device-tablet .live-iframe {
        max-width: 820px;
        height: calc(100% - 32px);
        box-shadow: 0 0 0 8px #1f2937, 0 12px 36px rgba(0, 0, 0, 0.2);
        border-radius: 16px;
      }

      /* === "미리보기 열기" 토글 버튼 — 패널 닫혀있을 때만 === */
      .live-show {
        position: fixed;
        top: 50%;
        right: 0;
        transform: translateY(-50%);
        z-index: 99998;
        background: #2060ad;
        color: white;
        border: 0;
        padding: 12px 10px 12px 14px;
        border-radius: 10px 0 0 10px;
        cursor: pointer;
        font-family: inherit;
        font-size: 12.5px;
        font-weight: 500;
        box-shadow: -4px 0 14px rgba(4, 44, 83, 0.18);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        writing-mode: vertical-rl;
        letter-spacing: 1.5px;
        transition: background 0.15s, padding-right 0.2s;
      }
      .live-show:hover {
        background: #194b88;
        padding-right: 14px;
      }
      .live-show i { font-size: 16px; writing-mode: horizontal-tb; }
      body.preview-open .live-show { display: none; }

      /* === 상단 도움말 toolbar === */
      .admin-toolbar {
        position: fixed;
        top: 12px;
        right: 16px;
        z-index: 99997;
        display: flex;
        gap: 8px;
        align-items: center;
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(4, 44, 83, 0.12);
        border-radius: 999px;
        padding: 6px 6px 6px 14px;
        box-shadow: 0 4px 16px rgba(4, 44, 83, 0.1);
        font-size: 13px;
        transition: right 0.25s ease;
      }
      body.preview-open .admin-toolbar {
        right: calc(var(--preview-w) + 16px);
      }
      .admin-toolbar .label {
        color: #2060ad;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .admin-toolbar .label i { font-size: 16px; }
      .admin-toolbar .divider {
        width: 1px; height: 18px;
        background: rgba(4, 44, 83, 0.15);
      }
      .admin-toolbar a.btn,
      .admin-toolbar button.btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 999px;
        background: #2060ad;
        color: white;
        text-decoration: none;
        font-weight: 500;
        font-size: 12.5px;
        transition: background 0.15s, transform 0.15s;
        border: 0;
        cursor: pointer;
        font-family: inherit;
      }
      .admin-toolbar a.btn:hover,
      .admin-toolbar button.btn:hover { background: #194b88; transform: translateY(-1px); }
      .admin-toolbar a.btn i,
      .admin-toolbar button.btn i { font-size: 15px; }
      .admin-toolbar a.btn-secondary {
        background: transparent;
        color: #2060ad;
        border: 1px solid rgba(32, 96, 173, 0.3);
      }
      .admin-toolbar a.btn-secondary:hover { background: rgba(32, 96, 173, 0.08); }

      @media (max-width: 900px) {
        .live-pane { width: 100vw !important; min-width: 100vw; }
        body.preview-open #nc-root { right: 0; }
        .live-resizer { display: none; }
        .admin-toolbar { right: 10px !important; padding: 4px 4px 4px 10px; font-size: 12px; }
        body.preview-open .admin-toolbar { right: 10px !important; }
        .admin-toolbar .label span,
        .admin-toolbar a.btn span,
        .admin-toolbar button.btn span { display: none; }
      }
    </style>
  </head>
  <body>
    <div id="nc-root"></div>

    <aside class="live-pane" id="live-pane" aria-hidden="true">
      <div
        class="live-resizer"
        id="live-resizer"
        role="separator"
        aria-orientation="vertical"
        aria-label="미리보기 패널 너비 조절 (드래그)"
        tabindex="0"
      ></div>
      <div class="live-toolbar">
        <span class="title">
          <i class="ti ti-eye"></i>
        </span>
        <div class="device-group" role="group" aria-label="기기 미리보기">
          <button class="device-btn active" type="button" data-device="desktop" title="데스크탑">
            <i class="ti ti-device-desktop"></i>
          </button>
          <button class="device-btn" type="button" data-device="tablet" title="태블릿">
            <i class="ti ti-device-tablet"></i>
          </button>
          <button class="device-btn" type="button" data-device="mobile" title="모바일">
            <i class="ti ti-device-mobile"></i>
          </button>
        </div>
        <input
          class="live-url"
          id="live-url"
          type="text"
          value="/"
          aria-label="미리보기 URL"
        />
        <a id="live-open" href="/" target="_blank" rel="noopener" title="새 창에서 열기" aria-label="새 창에서 열기">
          <i class="ti ti-external-link"></i>
        </a>
        <button id="live-refresh" type="button" title="새로고침" aria-label="새로고침">
          <i class="ti ti-refresh"></i>
        </button>
        <button id="live-collapse" type="button" title="패널 닫기" aria-label="패널 닫기">
          <i class="ti ti-x"></i>
        </button>
      </div>
      <div class="live-iframe-wrap" id="live-iframe-wrap">
        <iframe
          class="live-iframe"
          id="live-iframe"
          title="ASEZ 사이트 미리보기"
        ></iframe>
      </div>
    </aside>

    <button class="live-show" id="live-show" type="button" aria-label="미리보기 패널 열기">
      <i class="ti ti-eye"></i>
      미리보기
    </button>

    <div class="admin-toolbar" role="toolbar" aria-label="관리자 도구">
      <span class="label">
        <i class="ti ti-shield-lock"></i>
        <span>ASEZ 관리자</span>
      </span>
      <span class="divider"></span>
      <button class="btn" type="button" id="toolbar-preview-toggle" title="분할 미리보기 열기/닫기">
        <i class="ti ti-layout-sidebar-right"></i>
        <span>분할 미리보기</span>
      </button>
      <a class="btn" href="/admin-guide" target="_blank" rel="noopener">
        <i class="ti ti-book-2"></i>
        <span>가이드</span>
      </a>
      <a class="btn btn-secondary" href="/" target="_blank" rel="noopener" aria-label="사이트 새 창에서 열기">
        <i class="ti ti-external-link"></i>
        <span>새 창</span>
      </a>
    </div>

    <script
      is:inline
      src="https://unpkg.com/decap-cms@^3.4.0/dist/decap-cms.js"
    ></script>

    <!-- Decap markdown 미리보기 패널에 사이트 CSS + 커스텀 템플릿 -->
    <script is:inline>
      (function setupPreview() {
        if (!window.CMS) { setTimeout(setupPreview, 100); return; }
        const CMS = window.CMS;
        CMS.registerPreviewStyle("/admin/preview.css");

        const h = window.h || (window.React && window.React.createElement);
        if (!h) return;

        function StoryPreview({ entry, widgetFor }) {
          const data = entry.get("data");
          const title = data.get("title") || "(제목 없음)";
          const category = data.get("category");
          const date = data.get("date");
          const location = data.get("location");
          const image = data.get("image");
          const pillBg = data.get("pillBg") || "var(--brand-50)";
          const pillColor = data.get("pillColor") || "var(--brand-darker)";
          const fmtDate = date ? new Date(date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) : null;
          return h("article", { className: "story-preview" },
            h("div", { className: "cms-preview-hero" },
              category && h("span", { className: "pill", style: { background: pillBg, color: pillColor } }, category),
              h("h1", null, title),
              h("p", { className: "meta" },
                fmtDate && h("span", null, "📅 " + fmtDate),
                location && h("span", null, "📍 " + location),
              ),
            ),
            image && h("img", { src: image, alt: title, style: { width: "100%", aspectRatio: "16/8", objectFit: "cover", borderRadius: "8px", marginBottom: "32px" } }),
            widgetFor("body") || h("p", { className: "cms-preview-empty" }, "본문이 비어 있습니다."),
          );
        }
        CMS.registerPreviewTemplate("stories", StoryPreview);

        function ReportPreview({ entry, widgetFor }) {
          const data = entry.get("data");
          const title = data.get("title") || "(제목 없음)";
          const type = data.get("type");
          const date = data.get("date");
          const pages = data.get("pages");
          const excerpt = data.get("excerpt");
          const pillBg = data.get("pillBg") || "var(--brand-50)";
          const pillColor = data.get("pillColor") || "var(--brand-darker)";
          const fmtDate = date ? new Date(date).toLocaleDateString("en-US", { year: "numeric", month: "long" }) : null;
          return h("article", null,
            h("div", { className: "cms-preview-hero" },
              type && h("span", { className: "pill", style: { background: pillBg, color: pillColor } }, type),
              h("h1", null, title),
              h("p", { className: "meta" },
                fmtDate && h("span", null, "📅 " + fmtDate),
                pages && h("span", null, "📄 " + pages + "p"),
              ),
            ),
            excerpt && h("p", { style: { fontSize: "19px", color: "var(--text-secondary)", lineHeight: 1.6 } }, excerpt),
            widgetFor("body") || h("p", { className: "cms-preview-empty" }, "본문이 비어 있습니다."),
          );
        }
        CMS.registerPreviewTemplate("reports", ReportPreview);

        function EventPreview({ entry }) {
          const data = entry.get("data");
          const title = data.get("title") || "(제목 없음)";
          const type = data.get("type");
          const date = data.get("date");
          const endDate = data.get("endDate");
          const location = data.get("location");
          const excerpt = data.get("excerpt");
          const pillBg = data.get("pillBg") || "var(--brand-50)";
          const pillColor = data.get("pillColor") || "var(--brand-darker)";
          const fmtDate = (d) => d ? new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) : null;
          const dateStr = endDate ? fmtDate(date) + " — " + fmtDate(endDate) : fmtDate(date);
          return h("article", null,
            h("div", { className: "cms-preview-hero" },
              type && h("span", { className: "pill", style: { background: pillBg, color: pillColor } }, type),
              h("h1", null, title),
              h("p", { className: "meta" },
                dateStr && h("span", null, "📅 " + dateStr),
                location && h("span", null, "📍 " + location),
              ),
            ),
            excerpt && h("p", { style: { fontSize: "17px", lineHeight: 1.7 } }, excerpt),
          );
        }
        CMS.registerPreviewTemplate("events", EventPreview);

        function IssuePreview({ entry, widgetFor }) {
          const data = entry.get("data");
          const title = data.get("title") || "(제목 없음)";
          const tagline = data.get("tagline");
          const summary = data.get("summary");
          return h("article", null,
            h("div", { className: "cms-preview-hero" },
              h("h1", null, title),
              tagline && h("p", { style: { fontSize: "20px", color: "var(--brand)", fontWeight: 500, margin: "0 0 16px" } }, tagline),
              summary && h("p", { style: { fontSize: "17px", color: "var(--text-secondary)", lineHeight: 1.65, margin: 0 } }, summary),
            ),
            widgetFor("body") || h("p", { className: "cms-preview-empty" }, "본문이 비어 있습니다."),
          );
        }
        CMS.registerPreviewTemplate("issues", IssuePreview);
      })();
    </script>

    <!-- 분할 미리보기 컨트롤러 -->
    <script is:inline>
      const body = document.body;
      const pane = document.getElementById("live-pane");
      const showBtn = document.getElementById("live-show");
      const toggleBtn = document.getElementById("toolbar-preview-toggle");
      const collapseBtn = document.getElementById("live-collapse");
      const refreshBtn = document.getElementById("live-refresh");
      const openLink = document.getElementById("live-open");
      const urlInput = document.getElementById("live-url");
      const iframe = document.getElementById("live-iframe");
      const iframeWrap = document.getElementById("live-iframe-wrap");
      const resizer = document.getElementById("live-resizer");

      const K_PATH = "asez_cms_preview_path";
      const K_OPEN = "asez_cms_preview_open";
      const K_W = "asez_cms_preview_w";
      const K_DEVICE = "asez_cms_preview_device";

      function appendCmsFlag(p) {
        if (!p) p = "/";
        if (!p.startsWith("/")) p = "/" + p;
        return p + (p.includes("?") ? "&" : "?") + "cms=1";
      }

      function loadUrl(p) {
        if (!p) p = "/";
        if (!p.startsWith("/")) p = "/" + p;
        localStorage.setItem(K_PATH, p);
        iframe.src = appendCmsFlag(p);
        openLink.href = p;
        urlInput.value = p;
      }

      function setOpen(open) {
        body.classList.toggle("preview-open", open);
        pane.setAttribute("aria-hidden", open ? "false" : "true");
        localStorage.setItem(K_OPEN, open ? "1" : "0");
        if (open && !iframe.src) {
          // lazy load — 첫 열림에만
          const p = localStorage.getItem(K_PATH) || "/";
          loadUrl(p);
        }
      }

      function applyDevice(device) {
        iframeWrap.classList.remove("device-mobile", "device-tablet", "device-desktop");
        if (device !== "desktop") iframeWrap.classList.add("device-" + device);
        document.querySelectorAll(".device-btn").forEach((b) => {
          b.classList.toggle("active", b.dataset.device === device);
        });
        localStorage.setItem(K_DEVICE, device);
      }

      // === 너비 복원 === //
      const savedW = parseInt(localStorage.getItem(K_W) || "0", 10);
      if (savedW > 200 && savedW < window.innerWidth - 200) {
        document.documentElement.style.setProperty("--preview-w", savedW + "px");
      }

      // === 기기 복원 === //
      applyDevice(localStorage.getItem(K_DEVICE) || "desktop");

      // === 상태 복원 === //
      const wasOpen = localStorage.getItem(K_OPEN) === "1";
      if (wasOpen) setOpen(true);

      // === 토글 === //
      showBtn.addEventListener("click", () => setOpen(true));
      toggleBtn.addEventListener("click", () => setOpen(!body.classList.contains("preview-open")));
      collapseBtn.addEventListener("click", () => setOpen(false));

      // === URL 입력 + 새로고침 === //
      urlInput.addEventListener("change", () => loadUrl(urlInput.value));
      urlInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") { e.preventDefault(); loadUrl(urlInput.value); }
      });
      refreshBtn.addEventListener("click", () => { iframe.src = iframe.src; });

      // === 드래그 리사이즈 === //
      let dragging = false;
      let startX = 0;
      let startW = 0;
      function paneWidth() {
        return pane.getBoundingClientRect().width;
      }
      function onDragStart(clientX) {
        dragging = true;
        startX = clientX;
        startW = paneWidth();
        resizer.classList.add("active");
        body.classList.add("dragging");
      }
      function onDragMove(clientX) {
        if (!dragging) return;
        const dx = startX - clientX;
        const min = 280;
        const max = Math.min(window.innerWidth * 0.92, window.innerWidth - 200);
        const w = Math.max(min, Math.min(max, startW + dx));
        document.documentElement.style.setProperty("--preview-w", w + "px");
      }
      function onDragEnd() {
        if (!dragging) return;
        dragging = false;
        resizer.classList.remove("active");
        body.classList.remove("dragging");
        localStorage.setItem(K_W, String(paneWidth()));
      }
      resizer.addEventListener("mousedown", (e) => {
        e.preventDefault();
        onDragStart(e.clientX);
      });
      window.addEventListener("mousemove", (e) => onDragMove(e.clientX));
      window.addEventListener("mouseup", onDragEnd);
      resizer.addEventListener("touchstart", (e) => {
        if (e.touches[0]) { e.preventDefault(); onDragStart(e.touches[0].clientX); }
      }, { passive: false });
      window.addEventListener("touchmove", (e) => {
        if (e.touches[0]) onDragMove(e.touches[0].clientX);
      });
      window.addEventListener("touchend", onDragEnd);
      // 더블클릭으로 기본 너비 복귀
      resizer.addEventListener("dblclick", () => {
        document.documentElement.style.removeProperty("--preview-w");
        localStorage.removeItem(K_W);
      });

      // === 기기 버튼 === //
      document.querySelectorAll(".device-btn").forEach((btn) => {
        btn.addEventListener("click", () => applyDevice(btn.dataset.device));
      });

      // === 키보드 단축키 === //
      // Cmd/Ctrl + Shift + P → 미리보기 토글
      window.addEventListener("keydown", (e) => {
        if ((e.metaKey || e.ctrlKey) && e.shiftKey && (e.key === "P" || e.key === "p")) {
          e.preventDefault();
          setOpen(!body.classList.contains("preview-open"));
        }
        // ESC → 패널 닫기
        if (e.key === "Escape" && body.classList.contains("preview-open") && document.activeElement === urlInput) {
          // URL 입력 중에는 ESC가 닫지 않게 — 입력 blur만
          urlInput.blur();
        }
      });

      // === Decap entry 해시 → 자동으로 해당 페이지 URL 로드 === //
      const pathMap = {
        stories: (slug) => slug ? `/stories/${slug}` : "/stories",
        reports: () => "/reports",
        events: () => "/get-involved/events",
        issues: (slug) => slug ? `/what-we-do/${slug}` : "/what-we-do",
      };
      const filePathMap = {
        hero: "/", catchphrase: "/", stats: "/", projects: "/",
        regions: "/", recognition: "/", videos: "/", sns: "/", footer: "/",
        about: "/about", contact: "/contact",
        where_we_work: "/where-we-work", what_we_do: "/what-we-do",
        get_involved: "/get-involved",
        join: "/get-involved/join", start_chapter: "/get-involved/start-chapter",
        volunteer: "/get-involved/volunteer", partner: "/get-involved/partner",
      };
      function syncPathFromHash() {
        const m = location.hash.match(/^#\/collections\/([^/]+)\/(?:entries\/([^/]+)|new)/);
        if (!m) return;
        const coll = m[1];
        const slug = m[2];
        let target = null;
        if (pathMap[coll]) target = pathMap[coll](slug);
        else if (filePathMap[slug]) target = filePathMap[slug];
        if (target && body.classList.contains("preview-open") && target !== urlInput.value) {
          loadUrl(target);
        }
      }
      window.addEventListener("hashchange", syncPathFromHash);
      setTimeout(syncPathFromHash, 500);
    </script>
  </body>
</html>
