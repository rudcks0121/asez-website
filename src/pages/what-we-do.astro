---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import IssueGrid from "../components/IssueGrid.astro";
import ComingSoon from "../components/ComingSoon.astro";
import CtaBanner from "../components/CtaBanner.astro";
import page from "../data/cms/page-what-we-do.json";

const lang = "en" as const;
const c = page.en;
const campaigns = page.campaigns.map((cp: any) => ({ ...cp, ...(cp[lang] ?? cp.en) }));
---

<BaseLayout title={c.title} description={c.description}>
  <Header />
  <PageHero
    eyebrow={c.hero.eyebrow}
    icon="ti-target-arrow"
    title={c.hero.title}
    lead={c.hero.lead}
  />
  <main>
    <IssueGrid />

    <section class="campaigns reveal">
      <div class="inner">
        <div class="head">
          <div>
            <p class="eyebrow">{c.campaigns.eyebrow}</p>
            <h2>{c.campaigns.title}</h2>
          </div>
        </div>
        <div class="list">
          {campaigns.map((cp: any, i: number) => (
            <a class="campaign" href={cp.href} class:list={["campaign", i % 2 === 1 && "reverse"]}>
              <div class="media">
                <img src={cp.image} alt={cp.title} loading="lazy" />
              </div>
              <div class="body">
                <span class="pill" style={`background: ${cp.pillBg}; color: ${cp.pillColor};`}>
                  {cp.pill}
                </span>
                <h3>{cp.title}</h3>
                <p>{cp.desc}</p>
                <span class="more">
                  {c.campaigns.readMore} <i class="ti ti-arrow-right"></i>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CtaBanner variant="join" />
    <ComingSoon message={c.comingSoon} />
  </main>
  <Footer />
</BaseLayout>

<style>
  .campaigns {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .head { margin-bottom: 40px; }
  .head h2 {
    font-size: var(--fs-h2);
    margin: 0;
    letter-spacing: -0.4px;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .campaign {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 36px;
    align-items: center;
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-primary);
    text-decoration: none;
    padding: 28px;
    transition:
      border-color 0.2s,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease;
  }
  .campaign:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(4, 44, 83, 0.08);
  }
  .campaign.reverse .media { order: 2; }
  .campaign.reverse .body { order: 1; }
  .media {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: var(--radius-md);
    position: relative;
  }
  .media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .campaign:hover .media img { transform: scale(1.04); }
  .body { padding: 8px 12px; }
  .pill {
    display: inline-block;
    font-size: var(--fs-caption);
    font-weight: 500;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: 14px;
  }
  .body h3 {
    font-size: 26px;
    line-height: 1.2;
    margin: 0 0 14px;
    letter-spacing: -0.4px;
  }
  .body p {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 18px;
  }
  .more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--brand);
  }
  .more i { transition: transform 0.2s; }
  .campaign:hover .more i { transform: translateX(4px); }

  @media (max-width: 768px) {
    .campaigns { padding: 56px 20px; }
    .campaign {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 20px;
    }
    .campaign.reverse .media { order: 1; }
    .campaign.reverse .body { order: 2; }
    .body { padding: 0; }
    .body h3 { font-size: 22px; }
  }
</style>
