---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import ComingSoon from "../../components/ComingSoon.astro";
---

<BaseLayout
  title="Partner with us — ASEZ"
  description="For governments, universities, NGOs, and corporations seeking collaboration on SDGs."
>
  <Header />
  <PageHero
    eyebrow="Take part"
    icon="ti-handshake"
    title="Partner with ASEZ."
    lead="ASEZ has signed MOUs with 80+ organizations — UN agencies, governments, universities, and global NGOs. We're open to new partnerships aligned with the UN SDGs."
  />
  <main>
    <ComingSoon message="A partnership inquiry form with proposal templates is in development. For immediate proposals, reach partners@asez.org through the Contact page." />
  </main>
  <Footer />
</BaseLayout>
