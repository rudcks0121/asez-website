---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import ComingSoon from "../../components/ComingSoon.astro";
---

<BaseLayout
  title="Start a chapter — ASEZ"
  description="No ASEZ chapter on your campus yet? We'll help you start one."
>
  <Header />
  <PageHero
    eyebrow="Take part"
    title="Start an ASEZ chapter."
    lead="No chapter on your campus yet? We'll help. ASEZ supports new chapter founders with playbooks, regional mentorship, and a global peer network."
  />
  <main>
    <ComingSoon message="The new-chapter application process — including the founder's handbook and 90-day launch plan — is being finalized. Reach us through the Contact page to start the conversation." />
  </main>
  <Footer />
</BaseLayout>
