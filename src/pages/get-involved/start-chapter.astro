---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import ComingSoon from "../../components/ComingSoon.astro";
import CtaBanner from "../../components/CtaBanner.astro";

const steps = [
  { num: "1", title: "Gather 3–5 founding students", desc: "ASEZ chapters work best with a small founding team. Reach out to friends across departments who share your values." },
  { num: "2", title: "Submit a new-chapter application", desc: "Tell us your campus, founding members, and the issues you most want to tackle. We'll review within 7 days." },
  { num: "3", title: "Get matched with a regional mentor", desc: "An experienced chapter coordinator from your region guides the first 90 days — campus approval, first events, recruitment." },
  { num: "4", title: "Launch your first action", desc: "Most new chapters run a small tree-planting, cleanup, or forum within the first quarter. The playbook is ready when you are." },
];

const support = [
  { icon: "ti-book", title: "Founder's handbook", desc: "Step-by-step launch playbook from chapters who've done it." },
  { icon: "ti-users", title: "Peer network", desc: "Direct connection to nearby chapters for advice and joint events." },
  { icon: "ti-presentation", title: "Training materials", desc: "Workshop templates, campaign kits, presentation decks." },
  { icon: "ti-shield-check", title: "Brand assets", desc: "Logos, fonts, photography library — ready to use." },
];
---

<BaseLayout
  title="Start a chapter — ASEZ"
  description="No ASEZ chapter on your campus yet? We'll help you start one."
>
  <Header />
  <PageHero
    eyebrow="Take part"
    icon="ti-flag"
    title="Start an ASEZ chapter."
    lead="No chapter on your campus yet? We'll help. ASEZ supports new chapter founders with playbooks, regional mentorship, and a global peer network."
  />
  <main>
    <section class="steps reveal">
      <div class="inner">
        <p class="eyebrow">The process</p>
        <h2>Four steps to your launch day.</h2>
        <div class="grid">
          {steps.map((s) => (
            <div class="step">
              <div class="num">{s.num}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="support reveal">
      <div class="inner">
        <p class="eyebrow">What we provide</p>
        <h2>You won't start from zero.</h2>
        <div class="grid">
          {support.map((b) => (
            <div class="card">
              <i class={`ti ${b.icon}`}></i>
              <h3>{b.title}</h3>
              <p>{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CtaBanner variant="contact" />
    <ComingSoon message="The new-chapter application form is being finalized. For now, please contact us to start the conversation." />
  </main>
  <Footer />
</BaseLayout>

<style>
  .steps { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-primary); }
  .support { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-secondary); border-top: 0.5px solid var(--border); }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  h2 { font-size: var(--fs-h2); margin: 0 0 36px; letter-spacing: -0.4px; max-width: 640px; }
  .steps .grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; }
  .step { padding: 24px; border-radius: var(--radius-lg); background: var(--bg-secondary); border: 0.5px solid var(--border); transition: border-color 0.2s, transform 0.3s; }
  .step:hover { border-color: var(--border-strong); transform: translateY(-3px); }
  .num { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: var(--brand); color: white; font-size: 18px; font-weight: 500; margin-bottom: 14px; }
  .step h3 { font-size: 16px; margin: 0 0 6px; line-height: 1.3; }
  .step p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; margin: 0; }
  .support .grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; }
  .card { padding: 24px; background: var(--bg-primary); border-radius: var(--radius-md); border: 0.5px solid var(--border); }
  .card i { font-size: 28px; color: var(--brand); margin-bottom: 12px; display: inline-block; }
  .card h3 { font-size: var(--fs-h3); margin: 0 0 6px; }
  .card p { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.5; margin: 0; }
  @media (max-width: 900px) {
    .steps .grid, .support .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .steps, .support { padding: 56px 20px; }
    .steps .grid, .support .grid { grid-template-columns: 1fr; }
  }
</style>
