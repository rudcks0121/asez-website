---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import ComingSoon from "../../components/ComingSoon.astro";
import CtaBanner from "../../components/CtaBanner.astro";

const options = [
  { icon: "ti-leaf", title: "One-day actions", desc: "Tree plantings, beach cleanups, neighborhood forums — show up once and see what the work feels like." },
  { icon: "ti-calendar", title: "Recurring commitments", desc: "Weekly elderly care, monthly community service, or a recurring environmental project. Build a routine." },
  { icon: "ti-microphone", title: "Forums and conferences", desc: "Help organize or speak at ASEZ-hosted forums on climate, plastic, digital rights, and youth participation." },
  { icon: "ti-heart-handshake", title: "Disaster response", desc: "When a disaster strikes nearby, our regional teams activate volunteer drives within 48 hours." },
];

const steps = [
  { num: "1", title: "Tell us where you are", desc: "Country and city are enough — we route you to the regional team." },
  { num: "2", title: "Pick a starting point", desc: "Browse the events list, or let a coordinator suggest something for you." },
  { num: "3", title: "Show up", desc: "First time is the hardest. After that, you'll know where to plug in." },
];
---

<BaseLayout
  title="Volunteer with us — ASEZ"
  description="Open to community members of all ages. Join a local cleanup, forum, or campaign."
>
  <Header />
  <PageHero
    eyebrow="Take part"
    icon="ti-heart"
    title="Volunteer with ASEZ."
    lead="Not a university student? We welcome volunteers of all ages — for tree plantings, plastic cleanups, disaster relief, and community forums."
  />
  <main>
    <section class="options reveal">
      <div class="inner">
        <p class="eyebrow">Ways to help</p>
        <h2>Four kinds of volunteering.</h2>
        <div class="grid">
          {options.map((o) => (
            <div class="opt">
              <i class={`ti ${o.icon}`}></i>
              <h3>{o.title}</h3>
              <p>{o.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="steps reveal">
      <div class="inner">
        <p class="eyebrow">How to start</p>
        <h2>Three steps to your first activity.</h2>
        <div class="grid">
          {steps.map((s) => (
            <div class="step">
              <div class="num">{s.num}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CtaBanner variant="contact" />
    <ComingSoon message="A nearby-event finder and one-time volunteer sign-up are coming soon." />
  </main>
  <Footer />
</BaseLayout>

<style>
  .options { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-primary); }
  .steps { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-secondary); border-top: 0.5px solid var(--border); }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  h2 { font-size: var(--fs-h2); margin: 0 0 36px; letter-spacing: -0.4px; max-width: 640px; }
  .options .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
  .opt { padding: 26px; background: var(--bg-secondary); border-radius: var(--radius-lg); border: 0.5px solid var(--border); transition: border-color 0.2s, transform 0.3s; }
  .opt:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .opt i { font-size: 28px; color: var(--brand); margin-bottom: 14px; display: inline-block; }
  .opt h3 { font-size: var(--fs-h3); margin: 0 0 6px; }
  .opt p { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.55; margin: 0; }
  .steps .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
  .step { padding: 26px; background: var(--bg-primary); border-radius: var(--radius-lg); border: 0.5px solid var(--border); }
  .num { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: var(--brand); color: white; font-size: 18px; font-weight: 500; margin-bottom: 14px; }
  .step h3 { font-size: 16px; margin: 0 0 6px; }
  .step p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; margin: 0; }
  @media (max-width: 900px) {
    .options .grid, .steps .grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .options, .steps { padding: 56px 20px; }
  }
</style>
