    pillBg: "var(--brand-50)",
    pillColor: "var(--brand-900)",
  },
  {
    category: "Plastic-free",
    title: "Green Concert for a Plastic-Free India in Hyderabad",
    date: "October 14, 2025",
    imgUrl: "https://asez.org/wp-content/uploads/2024/10/thum_zero_plastic_2040.jpg",
    pillBg: "var(--teal-50)",
    pillColor: "var(--teal-900)",
  },
  {
    category: "Diplomacy",
    title: "Meeting With the President of East Timor",
    date: "February 5, 2026",
    imgUrl:
      "https://asez.org/wp-content/uploads/2026/02/%ED%8C%A8%EB%84%90-%EC%95%9E-%EB%8B%A8%EC%B2%B4%EC%82%AC%EC%A7%84-2-1.jpg",
    pillBg: "var(--amber-50)",
    pillColor: "var(--amber-900)",
  },
  {
    category: "Climate action",
    title: "Tree-Planting Reaches 20-Tree Milestone on Mears Road",
    date: "January 25, 2026",
    imgUrl:
      "https://asez.org/wp-content/uploads/2026/03/20260125_%EB%82%A8%EC%95%84%ED%94%84%EB%A6%AC%EC%B9%B4%EA%B3%B5%ED%99%94%EA%B5%AD_C_%EB%82%A8%EC%95%84%ED%94%84%EB%A6%AC%EC%B9%B4%EA%B3%B5%ED%99%94%EA%B5%AD-%ED%94%84%EB%A6%AC%ED%86%A0%EB%A6%AC%EC%95%84_ASEZ-%EB%82%98%EB%AC%B4%EC%8B%AC%EA%B8%B0-20%EA%B7%B8%EB%A3%A8_%EB%AF%B8%EC%96%B4%EC%8A%A4-%EB%8F%84%EB%A1%9C-%EB%A7%88%ED%81%B4%EB%89%B4%ED%81%AC_0000002_ASEZIUBA.jpg",
    pillBg: "var(--brand-50)",
    pillColor: "var(--brand-900)",
  },
  {
    category: "Climate action",
    title: "In the Era of Climate Crisis, Forests Become National Competitiveness",
    date: "October 8, 2025",
    imgUrl:
      "https://asez.org/wp-content/uploads/2026/03/beautiful-canopy-of-green-trees-looking-upwards-2026-01-11-10-01-30-utc-1.jpg",
