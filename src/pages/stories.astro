---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import StoryCard from "../components/StoryCard.astro";
import ComingSoon from "../components/ComingSoon.astro";

// 컬렉션에서 공개 스토리만 불러오고 날짜순 정렬
const allStories = await getCollection("stories", ({ data }) => !data.draft);
const stories = allStories.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

// 카테고리 동적 추출 (중복 제거)
const cats = Array.from(new Set(stories.map((s) => s.data.category)));
const filters = [{ label: "All stories", active: true }, ...cats.map((c) => ({ label: c, active: false }))];
---

<BaseLayout
  title="Stories — ASEZ"
  description="Field stories, press releases, and updates from ASEZ chapters around the world."
>
  <Header />
  <PageHero
    eyebrow="Stories"
    title="Voices from the field."
    lead="Updates, field reports, and press releases from ASEZ chapters around the world — across climate, plastic, crime, digital rights, and diplomacy."
  />
  <main>
    <section class="stories-section reveal">
      <div class="inner">
        <div class="filters" role="tablist" aria-label="Story categories">
          {filters.map((f) => (
            <button
              type="button"
              class:list={["filter", f.active && "active"]}
              role="tab"
              aria-selected={f.active ? "true" : "false"}
            >
              {f.label}
            </button>
          ))}
        </div>
        <div class="grid">
          {stories.map((s) => (
            <StoryCard
              category={s.data.category}
              title={s.data.title}
              date={fmt(s.data.date)}
              imgUrl={s.data.image}
              pillBg={s.data.pillBg}
              pillColor={s.data.pillColor}
              href={`/stories/${s.id}`}
            />
          ))}
        </div>
      </div>
    </section>
    <ComingSoon
      message="Working filters, full-text search, and pagination are coming soon."
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  .stories-section {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 0.5px solid var(--border);
  }
  .filter {
    background: transparent;
    border: 0.5px solid var(--border-strong);
    color: var(--text-secondary);
    border-radius: var(--radius-pill);
    padding: 8px 16px;
    font-size: var(--fs-small);
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .filter:hover {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }
  .filter.active {
    background: var(--brand);
    color: white;
    border-color: var(--brand);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .stories-section { padding: 56px 20px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
