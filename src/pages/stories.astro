    pillColor: "var(--brand-900)",
  },
  {
    category: "Plastic-free",
    title: "The Cost of Convenience — Reusable Cups Campaign",
    date: "March 17, 2026",
    imgUrl:
      "https://asez.org/wp-content/uploads/2026/04/closeup-image-of-a-couple-people-holding-and-drink-2026-03-17-17-45-23-utc.jpg",
    pillBg: "var(--teal-50)",
    pillColor: "var(--teal-900)",
  },
  {
    category: "Digital rights",
    title: "Digital Human Rights Campaign Launches Across Asia",
    date: "December 5, 2025",
    imgUrl: "https://asez.org/wp-content/uploads/2025/12/thum_digital_human_rights.jpg",
    pillBg: "var(--brand-50)",
    pillColor: "var(--brand-900)",
  },
  {
    category: "Climate action",
    title: "Blue Carbon Movement Begins 2026 Coastal Initiatives",
    date: "April 10, 2026",
    imgUrl: "https://asez.org/wp-content/uploads/2026/04/thum_blue_carbon_2026.jpg",
    pillBg: "var(--teal-50)",
    pillColor: "var(--teal-900)",
  },
  {
    category: "Recognition",
    title: "ASEZ Honored With UNCCD Executive Secretary's Award",
    date: "July 15, 2024",
    imgUrl: "https://asez.org/wp-content/uploads/2024/07/thum_unccd_award.png",
    pillBg: "var(--amber-50)",
    pillColor: "var(--amber-900)",
  },
];

const filters = [
  { label: "All stories", active: true },
  { label: "Climate action" },
  { label: "Plastic-free" },
  { label: "Crime prevention" },
  { label: "Digital rights" },
  { label: "Diplomacy" },
  { label: "Recognition" },
];
---

<BaseLayout
  title="Stories — ASEZ"
  description="Field stories, press releases, and updates from ASEZ chapters around the world."
>
  <Header />
  <PageHero
    eyebrow="Stories"
    title="Voices from the field."
    lead="Updates, field reports, and press releases from ASEZ chapters around the world — across climate, plastic, crime, digital rights, and diplomacy."
  />
  <main>
    <section class="stories-section reveal">
      <div class="inner">
        <div class="filters" role="tablist" aria-label="Story categories">
          {filters.map((f) => (
            <button
              type="button"
              class:list={["filter", f.active && "active"]}
              role="tab"
              aria-selected={f.active ? "true" : "false"}
            >
              {f.label}
            </button>
          ))}
        </div>
        <div class="grid">
          {stories.map((s) => <StoryCard {...s} />)}
        </div>
      </div>
    </section>
    <ComingSoon
      message="Working filters, full-text search, and pagination are coming soon."
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  .stories-section {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }

  .filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 0.5px solid var(--border);
  }
  .filter {
    background: transparent;
    border: 0.5px solid var(--border-strong);
    color: var(--text-secondary);
    border-radius: var(--radius-pill);
    padding: 8px 16px;
    font-size: var(--fs-small);
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .filter:hover {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }
  .filter.active {
    background: var(--brand);
    color: white;
    border-color: var(--brand);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .stories-section { padding: 56px 20px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
