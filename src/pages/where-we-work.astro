---
import worldMapRaw from "../data/world-map.svg?raw";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import ComingSoon from "../components/ComingSoon.astro";

export const prerender = true;

// 외곽 <svg>·메타데이터·defs 벗기고 country path 모음만 남김.
const worldMapPaths = worldMapRaw
  .replace(/<\?xml[^?]*\?>/g, "")
  .replace(/<!--[\s\S]*?-->/g, "")
  .replace(/<metadata[\s\S]*?<\/metadata>/g, "")
  .replace(/<defs[\s\S]*?<\/defs>/g, "")
  .replace(/<svg[^>]*>/, "")
  .replace(/<\/svg>\s*$/, "")
  .replace(/\s(inkscape|sodipodi):[a-z-]+="[^"]*"/g, "");

const regions = [
  { name: "Asia",     countries: 48, hq: "Seoul, South Korea" },
  { name: "Americas", countries: 35, hq: "Los Angeles, USA" },
  { name: "Europe",   countries: 44, hq: "London, United Kingdom" },
  { name: "Africa",   countries: 38, hq: "Nairobi, Kenya" },
  { name: "Oceania",  countries: 10, hq: "Sydney, Australia" },
];

const featuredCampuses = [
  { city: "Seoul",     country: "South Korea",    note: "Asia regional HQ" },
  { city: "New Delhi", country: "India",          note: "Plastic-Free India hub" },
  { city: "Pretoria",  country: "South Africa",   note: "Tree-planting program" },
  { city: "Manila",    country: "Philippines",    note: "Reduce Crime Together" },
  { city: "Lima",      country: "Peru",           note: "Amazon protection" },
  { city: "Dili",      country: "Timor-Leste",    note: "National partnership" },
  { city: "Sydney",    country: "Australia",      note: "Blue Carbon Pacific" },
  { city: "Nairobi",   country: "Kenya",          note: "Africa regional HQ" },
];

// HQ + 주요 캠퍼스 마커. viewBox 950x620 기준 좌표 (Wikimedia BlankMap-World 기준 경험적 추정).
const markers = [
  { x: 791, y: 200, city: "Seoul",       country: "South Korea",  role: "Asia HQ",     kind: "hq" },
  { x: 175, y: 250, city: "Los Angeles", country: "USA",          role: "Americas HQ", kind: "hq" },
  { x: 459, y: 178, city: "London",      country: "UK",           role: "Europe HQ",   kind: "hq" },
  { x: 575, y: 348, city: "Nairobi",     country: "Kenya",        role: "Africa HQ",   kind: "hq" },
  { x: 866, y: 466, city: "Sydney",      country: "Australia",    role: "Oceania HQ",  kind: "hq" },
  { x: 710, y: 250, city: "New Delhi",   country: "India",        role: "Plastic-Free India hub",     kind: "campus" },
  { x: 800, y: 305, city: "Manila",      country: "Philippines",  role: "Reduce Crime Together",      kind: "campus" },
  { x: 808, y: 372, city: "Dili",        country: "Timor-Leste",  role: "National partnership",       kind: "campus" },
  { x: 552, y: 428, city: "Pretoria",    country: "South Africa", role: "Tree-planting program",      kind: "campus" },
  { x: 250, y: 380, city: "Lima",        country: "Peru",         role: "Amazon protection",          kind: "campus" },
];

// ASEZ 활동 핵심 국가 (지도에서 brand 컬러로 강조).
const presence = [
  "south korea", "japan", "china", "india", "philippines", "indonesia",
  "vietnam", "thailand", "malaysia", "mongolia", "nepal", "sri lanka", "taiwan",
  "usa", "canada", "mexico", "brazil", "peru", "argentina", "chile", "colombia",
  "ecuador", "bolivia", "britain", "france", "germany", "italy", "spain",
  "poland", "ukraine", "netherlands", "ireland",
  "south africa", "kenya", "nigeria", "ghana", "ethiopia", "egypt",
  "tanzania", "uganda", "morocco",
  "australia", "papua new guinea", "luzon", "mindanao", "timor", "borneo",
];
const presenceSelector = presence.map((id) => `[id="${id}"]`).join(",");
---

<BaseLayout
  title="Where we work — ASEZ"
  description="ASEZ operates on every continent. Explore our regional presence and find a campus chapter near you."
>
  <Header />
  <PageHero
    eyebrow="Global presence"
    icon="ti-world"
    title="175 countries. 7,500 campuses. One movement."
    lead="ASEZ chapters operate on every continent. Find a chapter near you, or start one."
  />
  <main>
    <!-- Regions -->
    <section class="regions reveal">
      <div class="inner">
        <div class="grid">
          {regions.map((r) => (
            <div class="region">
              <div class="num">{r.countries}</div>
              <div class="label">{r.name}</div>
              <div class="sub">countries</div>
              <div class="hq">HQ — {r.hq}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Coverage map -->
    <style is:inline set:html={`
      .world-map .countries ${presence.map((id) => `[id="${id}"]`).join(",")} {
        fill: var(--brand) !important;
      }
      .world-map .countries ${presence.map((id) => `[id="${id}"]:hover`).join(",")} {
        fill: var(--brand-darker) !important;
      }
    `} />
    <section class="map-section reveal">
      <div class="inner">
        <div class="head">
          <p class="eyebrow">Coverage map</p>
          <h2>A network on every continent.</h2>
          <p class="intro">
            From Seoul to São Paulo, Cape Town to Sydney — ASEZ chapters
            are active in every major region. Hover the markers to see
            regional headquarters and flagship campuses.
          </p>
        </div>
        <div class="map-frame">
          <svg
            class="world-map"
            viewBox="0 0 950 620"
            preserveAspectRatio="xMidYMid meet"
            role="img"
            aria-label="World map showing ASEZ presence"
          >
            <g class="countries" set:html={worldMapPaths} />
            <g class="markers">
              {markers.map((m) => (
                <g class={`marker marker-${m.kind}`} tabindex="0">
                  <circle class="halo" cx={m.x} cy={m.y} r="10" />
                  <circle class="dot"  cx={m.x} cy={m.y} r="4.5" />
                  <g class="tip" transform={`translate(${m.x},${m.y})`}>
                    <rect x="10" y="-30" rx="4" ry="4" width="170" height="46" />
                    <text x="18" y="-13" class="tip-city">{m.city}</text>
                    <text x="18" y="2"   class="tip-meta">{m.country}</text>
                    <text x="18" y="14"  class="tip-role">{m.role}</text>
                  </g>
                </g>
              ))}
            </g>
          </svg>
          <div class="legend">
            <span class="lg lg-hq"><i></i> Regional HQ</span>
            <span class="lg lg-campus"><i></i> Featured campus</span>
            <span class="lg lg-presence"><i></i> Active chapters</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured campuses -->
    <section class="campuses reveal">
      <div class="inner">
        <div class="head">
          <p class="eyebrow">On the ground</p>
          <h2>Featured chapters.</h2>
          <p class="intro">
            A small selection of campuses leading flagship programs.
            The complete chapter directory is in development.
          </p>
        </div>
        <div class="grid">
          {featuredCampuses.map((c) => (
            <div class="campus">
              <div class="city">{c.city}</div>
              <div class="country">{c.country}</div>
              <div class="note">{c.note}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Find your chapter CTA -->
    <section class="find-cta reveal">
      <div class="inner">
        <div class="cta-card">
          <div>
            <p class="eyebrow light">For students</p>
            <h2>Find your campus chapter.</h2>
            <p class="desc">
              Searchable chapter directory and a "start a new chapter"
              process are coming soon. In the meantime, contact us and
              we'll connect you to the nearest team.
            </p>
          </div>
          <div class="cta-actions">
            <a href="/get-involved" class="btn-primary">Get involved</a>
            <a href="/contact" class="btn-outline">Contact us</a>
          </div>
        </div>
      </div>
    </section>

    <ComingSoon
      message="Regional offices directory and the full campus chapter listing are coming soon."
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* === Regions === */
  .regions {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .regions .inner { max-width: var(--max-width); margin: 0 auto; }
  .regions .grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 22px;
  }
  .region {
    border-top: 0.5px solid var(--border-strong);
    padding-top: 22px;
  }
  .num {
    font-size: 44px;
    font-weight: 500;
    color: var(--brand);
    line-height: 1;
    letter-spacing: -1px;
  }
  .label {
    font-size: 17px;
    font-weight: 500;
    margin-top: 14px;
  }
  .sub {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    margin-top: 2px;
  }
  .hq {
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
    margin-top: 12px;
  }

  /* === Coverage map === */
  .map-section {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .map-section .inner { max-width: var(--max-width); margin: 0 auto; }
  .head { margin-bottom: 36px; max-width: 680px; }
  .head h2 {
    font-size: var(--fs-h2);
    margin: 0 0 14px;
    letter-spacing: -0.4px;
  }
  .head .intro {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  .map-frame {
    position: relative;
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    overflow: hidden;
    padding: 20px;
  }
  .world-map { display: block; width: 100%; height: auto; }

  /* Country fills */
  .world-map :global(.countries path) {
    fill: var(--brand-100);
    stroke: white;
    stroke-width: 0.6;
    transition: fill 0.2s ease;
  }

  /* Markers */
  .world-map :global(.marker) { cursor: pointer; outline: none; }
  .world-map :global(.marker .halo) {
    fill: var(--brand);
    opacity: 0.18;
    transform-origin: center;
    transform-box: fill-box;
    animation: pulse 2.4s ease-out infinite;
  }
  .world-map :global(.marker-campus .halo) { fill: var(--amber-900, #b45309); opacity: 0.22; }
  .world-map :global(.marker .dot) {
    fill: var(--brand);
    stroke: white;
    stroke-width: 1.6;
  }
  .world-map :global(.marker-campus .dot) { fill: var(--amber-900, #b45309); }
  .world-map :global(.marker .tip) {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease;
  }
  .world-map :global(.marker:hover .tip),
  .world-map :global(.marker:focus .tip) { opacity: 1; }
  .world-map :global(.marker:hover .dot),
  .world-map :global(.marker:focus .dot) { r: 5.5; }

  .world-map :global(.tip rect) {
    fill: white;
    stroke: var(--border-strong, rgba(0,0,0,0.12));
    stroke-width: 0.5;
    filter: drop-shadow(0 4px 12px rgba(4, 44, 83, 0.18));
  }
  .world-map :global(.tip-city) {
    font-size: 11px; font-weight: 500;
    fill: var(--text-primary);
  }
  .world-map :global(.tip-meta) {
    font-size: 9px;
    fill: var(--text-secondary);
  }
  .world-map :global(.tip-role) {
    font-size: 9px; font-weight: 500;
    fill: var(--brand);
  }

  @keyframes pulse {
    0%   { transform: scale(1);   opacity: 0.32; }
    60%  { transform: scale(1.8); opacity: 0; }
    100% { transform: scale(1.8); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .world-map :global(.marker .halo) { animation: none; opacity: 0.25; }
  }

  /* Legend */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 18px;
    padding: 14px 18px;
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    font-size: var(--fs-caption);
    color: var(--text-secondary);
  }
  .lg { display: inline-flex; align-items: center; gap: 8px; }
  .lg i {
    display: inline-block;
    width: 10px; height: 10px;
    border-radius: 50%;
  }
  .lg-hq i       { background: var(--brand); }
  .lg-campus i   { background: var(--amber-900, #b45309); }
  .lg-presence i { background: var(--brand-100); border: 0.5px solid var(--brand); }


  /* === Featured campuses === */
  .campuses {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .campuses .inner { max-width: var(--max-width); margin: 0 auto; }
  .campuses .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }
  .campus {
    padding: 22px;
    border-radius: var(--radius-md);
    border: 0.5px solid var(--border);
    background: var(--bg-secondary);
    transition: border-color 0.2s, transform 0.2s;
  }
  .campus:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .city {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 4px;
    letter-spacing: -0.2px;
  }
  .country {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    margin-bottom: 12px;
  }
  .note {
    font-size: var(--fs-caption);
    color: var(--brand);
    font-weight: 500;
  }

  /* === Find chapter CTA === */
  .find-cta {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .cta-card {
    max-width: var(--max-width);
    margin: 0 auto;
    background-image: linear-gradient(
      135deg,
      var(--brand-darker) 0%,
      var(--brand-dark) 100%
    );
    color: white;
    border-radius: var(--radius-lg);
    padding: 56px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .cta-card .eyebrow.light { color: rgba(255, 255, 255, 0.7); }
  .cta-card h2 {
    font-size: 28px;
    margin: 0 0 14px;
    letter-spacing: -0.4px;
    line-height: 1.2;
  }
  .cta-card .desc {
    font-size: var(--fs-body);
    opacity: 0.85;
    line-height: 1.6;
    margin: 0;
    max-width: 480px;
  }
  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cta-actions .btn-primary,
  .cta-actions .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 22px;
    border-radius: var(--radius-md);
    font-size: var(--fs-small);
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.2s, background 0.2s, border-color 0.2s;
  }
  .cta-actions .btn-primary {
    background: white;
    color: var(--brand);
  }
  .cta-actions .btn-primary:hover { transform: translateY(-1px); }
  .cta-actions .btn-outline {
    background: transparent;
    color: white;
    border: 0.5px solid rgba(255, 255, 255, 0.5);
  }
  .cta-actions .btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
  }

  /* === Responsive === */
  @media (max-width: 900px) {
    .regions .grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 28px; }
    .campuses .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .cta-card { grid-template-columns: 1fr; padding: 40px; }
  }
  @media (max-width: 560px) {
    .regions, .map-section, .campuses, .find-cta { padding: 56px 20px; }
    .regions .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .num { font-size: 36px; }
    .campuses .grid { grid-template-columns: 1fr; }
    .cta-card { padding: 32px 24px; }
  }
</style>
