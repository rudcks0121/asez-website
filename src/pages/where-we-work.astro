---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import ComingSoon from "../components/ComingSoon.astro";
import { countries, markers, viewBox, mapWidth, mapHeight } from "../lib/world-map";
import page from "../data/cms/page-where-we-work.json";
import { pathLocalized } from "../i18n/utils";

export const prerender = true;

const lang = "en" as const;
const c = page.en;
const regions = page.regions.map((r: any) => ({ ...r, ...(r[lang] ?? r.en) }));
const featuredCampuses = page.featuredCampuses.map((cm: any) => cm[lang] ?? cm.en);
const p = (path: string) => pathLocalized(path, lang);
---

<BaseLayout
  title={c.title}
  description={c.description}
>
  <Header />
  <PageHero
    eyebrow={c.hero.eyebrow}
    icon="ti-world"
    title={c.hero.title}
    lead={c.hero.lead}
  />
  <main>
    <!-- Regions -->
    <section class="regions reveal">
      <div class="inner">
        <div class="grid">
          {regions.map((r: any) => (
            <div class="region">
              <div class="num">{r.countries}</div>
              <div class="label">{r.name}</div>
              <div class="sub">{c.regions.countriesLabel}</div>
              <div class="hq">{c.regions.hqPrefix} {r.hq}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Coverage map -->
    <section class="map-section reveal">
      <div class="inner">
        <div class="head">
          <p class="eyebrow">{c.map.eyebrow}</p>
          <h2>{c.map.title}</h2>
          <p class="intro">{c.map.intro}</p>
        </div>
        <div class="map-card">
          <div class="map-frame">
            <svg
              class="world-map"
              viewBox={viewBox}
              preserveAspectRatio="xMidYMid meet"
              role="img"
              aria-label="World map showing ASEZ presence"
            >
              <defs>
                <radialGradient id="map-glow" cx="50%" cy="50%" r="65%">
                  <stop offset="0%"  stop-color="#dbeafe" stop-opacity="0.55"/>
                  <stop offset="100%" stop-color="#dbeafe" stop-opacity="0"/>
                </radialGradient>
                <filter id="hq-glow" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="2.4" />
                </filter>
              </defs>
              <rect width={mapWidth} height={mapHeight} fill="url(#map-glow)" />

              <g class="countries">
                {countries.map((c) => (
                  <path
                    d={c.d}
                    class:list={[
                      "country",
                      { "is-active": c.active },
                      `cont-${c.continent}`,
                    ]}
                    data-name={c.name}
                  />
                ))}
              </g>

              <g class="markers">
                {markers.map((m) => (
                  <g class:list={["marker", `marker-${m.kind}`]} tabindex="0">
                    <circle class="ring"  cx={m.x} cy={m.y} r="9" />
                    <circle class="halo"  cx={m.x} cy={m.y} r="6.5" />
                    <circle class="dot"   cx={m.x} cy={m.y} r="3.2" />
                    <g class="tip" transform={`translate(${m.x},${m.y})`}>
                      <rect x="11" y="-32" rx="6" ry="6" width="160" height="50" />
                      <text x="20" y="-15" class="tip-city">{m.city}</text>
                      <text x="20" y="-1"  class="tip-meta">{m.country}</text>
                      <text x="20" y="12"  class="tip-role">{m.role}</text>
                    </g>
                  </g>
                ))}
              </g>
            </svg>

            <div class="map-stats">
              <div class="stat"><span class="n">175</span><span class="l">{c.map.statCountries}</span></div>
              <div class="stat"><span class="n">7,500</span><span class="l">{c.map.statCampuses}</span></div>
              <div class="stat"><span class="n">5</span><span class="l">{c.map.statHqs}</span></div>
            </div>
          </div>

          <div class="legend">
            <span class="lg lg-hq"><i></i> {c.map.legendHq}</span>
            <span class="lg lg-campus"><i></i> {c.map.legendCampus}</span>
            <span class="lg lg-presence"><i></i> {c.map.legendActive}</span>
            <span class="lg lg-other"><i></i> {c.map.legendOther}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured campuses -->
    <section class="campuses reveal">
      <div class="inner">
        <div class="head">
          <p class="eyebrow">{c.campuses.eyebrow}</p>
          <h2>{c.campuses.title}</h2>
          <p class="intro">{c.campuses.intro}</p>
        </div>
        <div class="grid">
          {featuredCampuses.map((cm: any) => (
            <div class="campus">
              <div class="city">{cm.city}</div>
              <div class="country">{cm.country}</div>
              <div class="note">{cm.note}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Find your chapter CTA -->
    <section class="find-cta reveal">
      <div class="inner">
        <div class="cta-card">
          <div>
            <p class="eyebrow light">{c.findCta.eyebrow}</p>
            <h2>{c.findCta.title}</h2>
            <p class="desc">{c.findCta.desc}</p>
          </div>
          <div class="cta-actions">
            <a href={p(page.ctaPrimaryHref)} class="btn-primary">{c.findCta.ctaPrimary}</a>
            <a href={p(page.ctaSecondaryHref)} class="btn-outline">{c.findCta.ctaSecondary}</a>
          </div>
        </div>
      </div>
    </section>

    <ComingSoon message={c.comingSoon} />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* === Regions === */
  .regions {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .regions .inner { max-width: var(--max-width); margin: 0 auto; }
  .regions .grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 22px;
  }
  .region {
    border-top: 0.5px solid var(--border-strong);
    padding-top: 22px;
  }
  .num {
    font-size: 44px;
    font-weight: 500;
    color: var(--brand);
    line-height: 1;
    letter-spacing: -1px;
  }
  .label {
    font-size: 17px;
    font-weight: 500;
    margin-top: 14px;
  }
  .sub {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    margin-top: 2px;
  }
  .hq {
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
    margin-top: 12px;
  }

  /* === Coverage map === */
  .map-section {
    padding: var(--section-pad-y) var(--section-pad-x);
    background:
      radial-gradient(circle at 80% -10%, rgba(32, 96, 173, 0.06), transparent 50%),
      var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .map-section .inner { max-width: var(--max-width); margin: 0 auto; }
  .head { margin-bottom: 36px; max-width: 680px; }
  .head h2 {
    font-size: var(--fs-h2);
    margin: 0 0 14px;
    letter-spacing: -0.4px;
  }
  .head .intro {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .map-card {
    position: relative;
    background:
      radial-gradient(ellipse at 25% 100%, rgba(32, 96, 173, 0.04), transparent 60%),
      linear-gradient(180deg, #ffffff 0%, #fbfcfd 100%);
    border-radius: 20px;
    border: 0.5px solid var(--border);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 30px 60px -30px rgba(4, 44, 83, 0.18),
      0 8px 24px -12px rgba(4, 44, 83, 0.08);
    overflow: hidden;
  }
  .map-frame {
    position: relative;
    padding: 24px 28px 12px;
  }
  .world-map {
    display: block;
    width: 100%;
    height: auto;
    font-family: var(--font-sans, "Inter", system-ui, sans-serif);
  }

  /* Country fills (base) */
  .country {
    fill: #e8eef5;
    stroke: #ffffff;
    stroke-width: 0.5;
    stroke-linejoin: round;
    transition: fill 0.25s ease, transform 0.25s ease;
  }
  .country.is-active {
    fill: var(--brand);
  }
  .country:not(.is-active):hover {
    fill: #c7d3e0;
  }
  .country.is-active:hover {
    fill: var(--brand-darker, #1a4d8c);
  }
  .country.cont-antarctica { opacity: 0.35; }

  /* Markers */
  .marker { cursor: pointer; outline: none; }
  .marker .ring {
    fill: none;
    stroke: var(--brand);
    stroke-width: 1;
    opacity: 0;
    transform-origin: center;
    transform-box: fill-box;
    animation: ringPulse 2.4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .marker-campus .ring { stroke: #ea580c; }
  .marker .halo {
    fill: var(--brand);
    opacity: 0.18;
  }
  .marker-campus .halo { fill: #ea580c; opacity: 0.22; }
  .marker .dot {
    fill: white;
    stroke: var(--brand);
    stroke-width: 2;
    transition: r 0.2s ease;
  }
  .marker-campus .dot { stroke: #ea580c; }
  .marker:hover .dot,
  .marker:focus .dot { r: 4.6; }

  .marker .tip {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease;
  }
  .marker:hover .tip,
  .marker:focus .tip { opacity: 1; }

  .tip rect {
    fill: white;
    stroke: rgba(4, 44, 83, 0.08);
    stroke-width: 0.5;
    filter: drop-shadow(0 6px 16px rgba(4, 44, 83, 0.22));
  }
  .tip-city {
    font-size: 11px;
    font-weight: 600;
    fill: var(--text-primary);
    letter-spacing: -0.1px;
  }
  .tip-meta {
    font-size: 9.5px;
    fill: var(--text-secondary);
  }
  .tip-role {
    font-size: 9.5px;
    font-weight: 500;
    fill: var(--brand);
  }
  .marker-campus .tip-role { fill: #ea580c; }

  @keyframes ringPulse {
    0%   { r: 6;  opacity: 0.55; }
    70%  { r: 16; opacity: 0; }
    100% { r: 16; opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .marker .ring { animation: none; opacity: 0; }
  }

  /* Floating stats over the map */
  .map-stats {
    position: absolute;
    left: 28px;
    bottom: 16px;
    display: flex;
    gap: 18px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 6px 20px -10px rgba(4, 44, 83, 0.18);
  }
  .stat { display: flex; flex-direction: column; align-items: flex-start; }
  .stat .n {
    font-size: 18px;
    font-weight: 800;
    color: var(--brand);
    line-height: 1;
    letter-spacing: -0.4px;
  }
  .stat .l {
    font-size: 10px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 4px;
  }

  /* Legend */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    padding: 16px 28px 22px;
    border-top: 0.5px solid var(--border);
    background: rgba(248, 250, 252, 0.6);
    font-size: var(--fs-caption);
    color: var(--text-secondary);
  }
  .lg { display: inline-flex; align-items: center; gap: 8px; }
  .lg i {
    display: inline-block;
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .lg-hq i       { background: white; border: 2px solid var(--brand); }
  .lg-campus i   { background: white; border: 2px solid #ea580c; }
  .lg-presence i { background: var(--brand); }
  .lg-other i    { background: #e8eef5; border: 0.5px solid #c7d3e0; }

  @media (max-width: 768px) {
    .map-frame { padding: 18px 14px 8px; }
    .map-stats {
      position: static;
      margin-top: 12px;
      width: 100%;
      justify-content: space-between;
    }
    .stat .n { font-size: 16px; }
    .legend { padding: 14px 18px 18px; gap: 14px 18px; }
    .tip-city { font-size: 13px; }
    .tip-meta, .tip-role { font-size: 11px; }
  }
  @media (max-width: 480px) {
    .map-card { border-radius: 14px; }
    .map-frame { padding: 14px 10px 6px; }
    .map-stats { gap: 10px; padding: 10px 12px; }
  }


  /* === Featured campuses === */
  .campuses {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .campuses .inner { max-width: var(--max-width); margin: 0 auto; }
  .campuses .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }
  .campus {
    padding: 22px;
    border-radius: var(--radius-md);
    border: 0.5px solid var(--border);
    background: var(--bg-secondary);
    transition: border-color 0.2s, transform 0.2s;
  }
  .campus:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .city {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 4px;
    letter-spacing: -0.2px;
  }
  .country {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    margin-bottom: 12px;
  }
  .note {
    font-size: var(--fs-caption);
    color: var(--brand);
    font-weight: 500;
  }

  /* === Find chapter CTA === */
  .find-cta {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .cta-card {
    max-width: var(--max-width);
    margin: 0 auto;
    background-image: linear-gradient(
      135deg,
      var(--brand-darker) 0%,
      var(--brand-dark) 100%
    );
    color: white;
    border-radius: var(--radius-lg);
    padding: 56px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .cta-card .eyebrow.light { color: rgba(255, 255, 255, 0.7); }
  .cta-card h2 {
    font-size: 28px;
    margin: 0 0 14px;
    letter-spacing: -0.4px;
    line-height: 1.2;
  }
  .cta-card .desc {
    font-size: var(--fs-body);
    opacity: 0.85;
    line-height: 1.6;
    margin: 0;
    max-width: 480px;
  }
  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cta-actions .btn-primary,
  .cta-actions .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 22px;
    border-radius: var(--radius-md);
    font-size: var(--fs-small);
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.2s, background 0.2s, border-color 0.2s;
  }
  .cta-actions .btn-primary {
    background: white;
    color: var(--brand);
  }
  .cta-actions .btn-primary:hover { transform: translateY(-1px); }
  .cta-actions .btn-outline {
    background: transparent;
    color: white;
    border: 0.5px solid rgba(255, 255, 255, 0.5);
  }
  .cta-actions .btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
  }

  /* === Responsive === */
  @media (max-width: 900px) {
    .regions .grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 28px; }
    .campuses .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .cta-card { grid-template-columns: 1fr; padding: 40px; }
  }
  @media (max-width: 560px) {
    .regions, .map-section, .campuses, .find-cta { padding: 56px 20px; }
    .regions .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .num { font-size: 36px; }
    .campuses .grid { grid-template-columns: 1fr; }
    .cta-card { padding: 32px 24px; }
  }
</style>
