---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import ComingSoon from "../components/ComingSoon.astro";

const categories = [
  {
    icon: "ti-file-text",
    title: "Annual reports",
    desc: "Year-in-review reports covering activities, financials, and impact.",
  },
  {
    icon: "ti-chart-line",
    title: "SDG progress",
    desc: "Our contribution toward each of the 17 UN Sustainable Development Goals.",
  },
  {
    icon: "ti-search",
    title: "Research & briefs",
    desc: "Field research on environment, education, and youth participation.",
  },
  {
    icon: "ti-scale",
    title: "Policy papers",
    desc: "Policy recommendations submitted to UN, governments, and partner bodies.",
  },
];
---

<BaseLayout
  title="Reports & insights — ASEZ"
  description="Annual reports, SDG progress, research, and policy papers from ASEZ."
>
  <Header />
  <PageHero
    eyebrow="Insights"
    title="Reports & research."
    lead="Documenting our work, measuring our impact, and sharing what we learn — so others can build on it."
  />
  <main>
    <section class="categories reveal">
      <div class="inner">
        <div class="grid">
          {categories.map((c) => (
            <div class="cat">
              <i class={`ti ${c.icon} icon`}></i>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    <ComingSoon
      message="Downloadable PDF reports and a research database are coming soon."
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  .categories {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .cat {
    padding: 28px;
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    background: var(--bg-secondary);
    transition: border-color 0.2s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cat:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .icon {
    font-size: 28px;
    color: var(--brand);
    margin-bottom: 14px;
    display: inline-block;
  }
  h3 {
    font-size: var(--fs-h3);
    margin: 0 0 8px;
    line-height: var(--lh-snug);
  }
  p {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 768px) {
    .categories { padding: 56px 20px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
