---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import ComingSoon from "../components/ComingSoon.astro";

const channels = [
  {
    icon: "ti-mail",
    title: "General inquiries",
    detail: "contact@asez.org",
    sub: "We aim to respond within 3 business days.",
  },
  {
    icon: "ti-news",
    title: "Press inquiries",
    detail: "press@asez.org",
    sub: "Media kit and interview requests.",
  },
  {
    icon: "ti-handshake",
    title: "Partnerships",
    detail: "partners@asez.org",
    sub: "For governments, NGOs, universities, and corporates.",
  },
];
---

<BaseLayout
  title="Contact — ASEZ"
  description="Reach ASEZ — general inquiries, press, partnerships, and regional offices."
>
  <Header />
  <PageHero
    eyebrow="Reach us"
    title="Contact ASEZ."
    lead="Questions, press inquiries, partnership proposals — we'd love to hear from you."
  />
  <main>
    <section class="channels reveal">
      <div class="inner">
        <div class="grid">
          {channels.map((c) => (
            <div class="channel">
              <i class={`ti ${c.icon} icon`}></i>
              <h3>{c.title}</h3>
              <p class="detail">{c.detail}</p>
              <p class="sub">{c.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    <ComingSoon
      message="Regional office directory and contact form are coming soon."
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  .channels {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .inner { max-width: var(--max-width); margin: 0 auto; }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }
  .channel {
    padding: 28px;
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    background: var(--bg-secondary);
  }
  .icon {
    font-size: 28px;
    color: var(--brand);
    margin-bottom: 14px;
    display: inline-block;
  }
  h3 {
    font-size: var(--fs-h3);
    margin: 0 0 10px;
    line-height: var(--lh-snug);
  }
  .detail {
    font-size: var(--fs-body);
    color: var(--brand);
    font-weight: 500;
    margin: 0 0 4px;
  }
  .sub {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .channels { padding: 56px 20px; }
  }
</style>
