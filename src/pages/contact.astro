---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import ComingSoon from "../components/ComingSoon.astro";

const channels = [
  {
    icon: "ti-mail",
    title: "General inquiries",
    detail: "contact@asez.org",
    sub: "We aim to respond within 3 business days.",
  },
  {
    icon: "ti-news",
    title: "Press inquiries",
    detail: "press@asez.org",
    sub: "Media kit, interview, and statement requests.",
  },
  {
    icon: "ti-handshake",
    title: "Partnerships",
    detail: "partners@asez.org",
    sub: "Governments, NGOs, universities, and corporates.",
  },
];

const offices = [
  { region: "Asia",     hq: "Seoul, South Korea",     email: "asia@asez.org" },
  { region: "Americas", hq: "Los Angeles, USA",       email: "americas@asez.org" },
  { region: "Europe",   hq: "London, United Kingdom", email: "europe@asez.org" },
  { region: "Africa",   hq: "Nairobi, Kenya",         email: "africa@asez.org" },
  { region: "Oceania",  hq: "Sydney, Australia",      email: "oceania@asez.org" },
];

const subjects = [
  "General inquiry",
  "Press / media",
  "Partnership proposal",
  "Volunteer / membership",
  "Other",
];
---

<BaseLayout
  title="Contact — ASEZ"
  description="Reach ASEZ — general inquiries, press, partnerships, regional offices, and a direct contact form."
>
  <Header />
  <PageHero
    eyebrow="Reach us"
    title="Contact ASEZ."
    lead="Questions, press inquiries, partnership proposals — we'd love to hear from you."
  />
  <main>
    <!-- Quick channels -->
    <section class="channels reveal">
      <div class="inner">
        <div class="grid">
          {channels.map((c) => (
            <div class="channel">
              <i class={`ti ${c.icon} icon`}></i>
              <h3>{c.title}</h3>
              <p class="detail">{c.detail}</p>
              <p class="sub">{c.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact form -->
    <section class="form-section reveal">
      <div class="inner">
        <div class="form-grid">
          <div class="copy">
            <p class="eyebrow">Send a message</p>
            <h2>Tell us what you need.</h2>
            <p>
              For anything that doesn't fit the channels above — drop us
              a message. We read every one and route it to the right team.
            </p>
          </div>
          <form class="form" onsubmit="event.preventDefault();">
            <div class="row">
              <label>
                <span>Your name</span>
                <input type="text" placeholder="Jane Park" required />
              </label>
              <label>
                <span>Email</span>
                <input type="email" placeholder="jane@example.com" required />
              </label>
            </div>
            <label>
              <span>Subject</span>
              <select required>
                {subjects.map((s) => <option>{s}</option>)}
              </select>
            </label>
            <label>
              <span>Message</span>
              <textarea rows="6" placeholder="What can we help with?" required></textarea>
            </label>
            <button type="submit" class="submit">
              Send message <i class="ti ti-arrow-right"></i>
            </button>
            <p class="fine">
              We'll only use your details to reply to this message.
            </p>
          </form>
        </div>
      </div>
    </section>

    <!-- Regional offices -->
    <section class="offices reveal">
      <div class="inner">
        <p class="eyebrow">Regional offices</p>
        <h2>Local contacts.</h2>
        <p class="intro">
          For chapter-level or regional questions, reach the nearest
          office directly.
        </p>
        <div class="grid">
          {offices.map((o) => (
            <div class="office">
              <p class="region">{o.region}</p>
              <p class="hq">{o.hq}</p>
              <a class="email" href={`mailto:${o.email}`}>{o.email}</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <ComingSoon
      message="A full office directory with phone numbers and on-site visit information is coming soon."
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* === Channels === */
  .channels {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
  }
  .channels .inner { max-width: var(--max-width); margin: 0 auto; }
  .channels .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }
  .channel {
    padding: 28px;
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    background: var(--bg-secondary);
    transition: border-color 0.2s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .channel:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .icon {
    font-size: 28px;
    color: var(--brand);
    margin-bottom: 14px;
    display: inline-block;
  }
  .channel h3 {
    font-size: var(--fs-h3);
    margin: 0 0 10px;
    line-height: var(--lh-snug);
  }
  .detail {
    font-size: var(--fs-body);
    color: var(--brand);
    font-weight: 500;
    margin: 0 0 4px;
  }
  .sub {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* === Form === */
  .form-section {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-secondary);
    border-top: 0.5px solid var(--border);
  }
  .form-section .inner { max-width: var(--max-width); margin: 0 auto; }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 56px;
    align-items: start;
  }
  .copy h2 {
    font-size: var(--fs-h2);
    margin: 0 0 16px;
    letter-spacing: -0.4px;
  }
  .copy p {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 380px;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 18px;
    background: var(--bg-primary);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px;
  }
  .form .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form label span {
    font-size: var(--fs-caption);
    color: var(--text-secondary);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-weight: 500;
  }
  .form input,
  .form select,
  .form textarea {
    background: var(--bg-secondary);
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    font-size: var(--fs-body);
    color: var(--text-primary);
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .form textarea { resize: vertical; min-height: 120px; }
  .form input:focus,
  .form select:focus,
  .form textarea:focus {
    border-color: var(--brand);
    background: var(--bg-primary);
  }
  .form input::placeholder,
  .form textarea::placeholder {
    color: var(--text-tertiary);
  }
  .submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--brand);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    padding: 12px 24px;
    font-size: var(--fs-small);
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition:
      background 0.15s,
      transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s;
    margin-top: 4px;
  }
  .submit:hover {
    background: var(--brand-800);
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(32, 96, 173, 0.25);
  }
  .submit i { transition: transform 0.2s; }
  .submit:hover i { transform: translateX(3px); }
  .fine {
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
    margin: 0;
  }

  /* === Offices === */
  .offices {
    padding: var(--section-pad-y) var(--section-pad-x);
    background: var(--bg-primary);
    border-top: 0.5px solid var(--border);
  }
  .offices .inner { max-width: var(--max-width); margin: 0 auto; }
  .offices h2 {
    font-size: var(--fs-h2);
    margin: 0 0 14px;
    letter-spacing: -0.4px;
  }
  .offices .intro {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 0 40px;
  }
  .offices .grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 16px;
  }
  .office {
    padding: 22px;
    border-radius: var(--radius-md);
    border: 0.5px solid var(--border);
    background: var(--bg-secondary);
  }
  .office .region {
    font-size: var(--fs-caption);
    color: var(--brand);
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0 0 10px;
  }
  .office .hq {
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 8px;
    line-height: 1.4;
  }
  .office .email {
    font-size: var(--fs-small);
    color: var(--brand);
    text-decoration: none;
    word-break: break-all;
  }
  .office .email:hover { text-decoration: underline; }

  /* === Responsive === */
  @media (max-width: 900px) {
    .channels .grid { grid-template-columns: 1fr; }
    .form-grid { grid-template-columns: 1fr; gap: 32px; }
    .offices .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .channels, .form-section, .offices { padding: 56px 20px; }
    .form { padding: 24px; }
    .form .row { grid-template-columns: 1fr; }
    .offices .grid { grid-template-columns: 1fr; }
  }
</style>
